<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:HardwareVision.Controls">
    <ControlTemplate x:Key="MotionTransitionHostTemplate"
                     TargetType="{x:Type controls:MotionTransitionHost}">
        <Border x:Name="MotionSurface"
                MinWidth="0"
                MinHeight="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource AppBackgroundBrush}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="MotionTranslateTransform" />
            </Border.RenderTransform>
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
        </Border>
    </ControlTemplate>

    <Style x:Key="MotionTransitionHostStyle"
           TargetType="{x:Type controls:MotionTransitionHost}">
        <Setter Property="Template" Value="{StaticResource MotionTransitionHostTemplate}" />
        <Setter Property="AnimateInitialContent" Value="False" />
        <Setter Property="TransitionDirection" Value="FromRight" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
</ResourceDictionary>
