<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:HardwareVision.Controls">
    <Style x:Key="TraceworkPageRootStyle" TargetType="FrameworkElement">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="TraceworkPageHeaderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style x:Key="TraceworkPageCodeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="TraceworkPageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="TraceworkPageSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="TraceworkPanelStyle" TargetType="controls:TraceworkPanel">
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TraceworkPanel">
                    <Grid>
                        <Border x:Name="PanelBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{TemplateBinding Code}"
                                               Style="{DynamicResource TraceworkPanelCodeTextStyle}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,8,0"
                                               Text="{TemplateBinding Title}"
                                               Style="{DynamicResource TraceworkPanelTitleTextStyle}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{TemplateBinding BadgeText}"
                                               Style="{DynamicResource TraceworkPortLabelStyle}" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,4,0,9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{TemplateBinding Subtitle}"
                                               ToolTip="{TemplateBinding Subtitle}"
                                               Style="{DynamicResource TraceworkPanelSubtitleTextStyle}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="{TemplateBinding HeaderNote}"
                                               ToolTip="{TemplateBinding HeaderNote}"
                                               Style="{DynamicResource TraceworkPanelSourceTextStyle}" />
                                </Grid>

                                <ContentPresenter Grid.Row="2"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>
                        </Border>

                        <Path Width="12"
                              Height="12"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Data="M0,12 L12,0 L12,12 Z"
                              Fill="{DynamicResource AppBackgroundBrush}"
                              Stroke="{TemplateBinding BorderBrush}"
                              StrokeThickness="1" />
                        <Border Width="24"
                                Height="2"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{DynamicResource AccentBrush}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="PanelVariant" Value="Primary">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            </Trigger>
            <Trigger Property="PanelVariant" Value="Muted">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TraceworkHeroPanelStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkPanelStyle}">
        <Setter Property="PanelVariant" Value="Primary" />
        <Setter Property="MinHeight" Value="208" />
    </Style>

    <Style x:Key="TraceworkSecondaryPanelStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkPanelStyle}">
        <Setter Property="PanelVariant" Value="Default" />
        <Setter Property="MinHeight" Value="164" />
    </Style>

    <Style x:Key="TraceworkPanelCodeTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="TraceworkPanelTitleTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkPanelSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkPanelSourceTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxWidth" Value="180" />
    </Style>

    <Style x:Key="TraceworkHeroMetricLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkHeroMetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="27" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkMetricRowLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkMetricRowValueStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkDataStripStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkDataStripLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="TraceworkDataStripValueStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkStatusNotchStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkPortLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style x:Key="TraceworkDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,6" />
        <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
    </Style>

    <Style x:Key="TraceworkDashboardSelectorStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource DashboardHardwareComboBox}">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="TraceworkChartGridStyle" TargetType="ItemsControl">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="TraceworkChartCardStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="178" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkChartHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkChartCurrentValueStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkChartStatisticStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkChartWindowSelectorStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource DashboardHardwareComboBox}">
        <Setter Property="Width" Value="104" />
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="MaxWidth" Value="104" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style x:Key="TraceworkDataTablePanelStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkPanelStyle}">
        <Setter Property="MinHeight" Value="210" />
        <Setter Property="PanelVariant" Value="Muted" />
    </Style>

    <Style x:Key="TraceworkDataGridStyle"
           TargetType="DataGrid"
           BasedOn="{StaticResource RetroSensorDataGridStyle}">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource DividerBrush}" />
    </Style>

    <Style x:Key="TraceworkDataGridHeaderStyle"
           TargetType="DataGridColumnHeader"
           BasedOn="{StaticResource SensorTableHeaderCenterStyle}">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    </Style>

    <Style x:Key="TraceworkRowsBadgeStyle" TargetType="Border">
        <Setter Property="MinWidth" Value="62" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkRowsBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="TraceworkSensorNameTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SensorTableNameTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="TraceworkSensorTypeTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SensorTableTypeTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="TraceworkSensorValueTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SensorTableReadoutTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="TraceworkSensorStatusTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SensorTableStatusTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style x:Key="TraceworkGpuSelectorPanelStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkGpuSelectorStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource FutureComboBox}">
        <Setter Property="MinWidth" Value="280" />
        <Setter Property="MaxWidth" Value="520" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="TraceworkIdentityCardStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="58" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkIdentityLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TraceworkIdentityValueStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
</ResourceDictionary>
