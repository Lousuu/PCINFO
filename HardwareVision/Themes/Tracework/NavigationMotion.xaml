<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
                    xmlns:controls="clr-namespace:HardwareVision.Controls">
    <Style x:Key="RelayBandOverlayStyle" TargetType="{x:Type controls:RelayBandOverlay}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RelayBandOverlay}">
                    <Grid ClipToBounds="True">
                        <Border x:Name="PART_Band"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1,0"
                                Opacity="0">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AppBackground}" Opacity="0.94" />
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PART_Translate" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border Width="2"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource AccentBrush}" />
                                <Border Width="1"
                                        HorizontalAlignment="Right"
                                        Background="{DynamicResource DividerBrush}" />
                                <TextBlock x:Name="PART_Code"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TelemetryTitleTransitionHostStyle"
           TargetType="{x:Type controls:TelemetryTitleTransitionHost}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TelemetryTitleTransitionHost}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="PART_Code"
                                       Style="{StaticResource TraceworkSectionCodeTextStyle}">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="PART_CodeTranslate" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock x:Name="PART_Title"
                                       Margin="5,0,0,0"
                                       FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       automation:AutomationProperties.LiveSetting="Polite">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="PART_TitleTranslate" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock x:Name="PART_Subtitle"
                                   Margin="0,1,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{DynamicResource CaptionText}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
