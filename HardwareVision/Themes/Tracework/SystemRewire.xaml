<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:HardwareVision.Controls"
                    xmlns:models="clr-namespace:HardwareVision.Models">
    <ControlTemplate x:Key="SystemRewireOverlayTemplate"
                     TargetType="{x:Type controls:SystemRewireOverlay}">
        <Grid x:Name="PART_OverlayRoot"
              Background="#D6080D14"
              SnapsToDevicePixels="True"
              IsHitTestVisible="{TemplateBinding IsHitTestVisible}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="1"
                    Width="560"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                    Padding="28,24"
                    Background="#E20B111D"
                    BorderBrush="{DynamicResource AccentSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="0"
                                      Opacity="0.34"
                                      Color="#17D9C7" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="PART_RewireLabel"
                                   Text="SYSTEM REWIRE"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding Snapshot.StatusText, RelativeSource={RelativeSource TemplatedParent}}"
                                   Margin="0,8,0,0"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="PART_SourceNode"
                                Padding="14,12"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                Background="#90101824">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PART_SourceTranslateTransform" />
                            </Border.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="SOURCE"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding Snapshot.SourceCode, RelativeSource={RelativeSource TemplatedParent}}"
                                           Margin="0,6,0,0"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1"
                              Margin="14,0">
                            <Rectangle x:Name="PART_SpliceSegment"
                                       Height="1"
                                       VerticalAlignment="Center"
                                       Opacity="0.62"
                                       Fill="{DynamicResource AccentBrush}" />
                            <TextBlock Text="{Binding Snapshot.PhaseCode, RelativeSource={RelativeSource TemplatedParent}}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Padding="4,2"
                                       Background="#E20B111D"
                                       FontFamily="{DynamicResource MonoFontFamily}"
                                       FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Grid>

                        <Border x:Name="PART_TargetNode"
                                Grid.Column="2"
                                Padding="14,12"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                Background="#90101824">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PART_TargetTranslateTransform" />
                            </Border.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="TARGET"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding Snapshot.TargetCode, RelativeSource={RelativeSource TemplatedParent}}"
                                           Margin="0,6,0,0"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           FontSize="15"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4"
                            Height="3"
                            Background="{DynamicResource DividerBrush}">
                        <Border HorizontalAlignment="Left"
                                Width="190"
                                Background="{DynamicResource AccentBrush}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ControlTemplate>

    <Style x:Key="SystemRewireOverlayStyle"
           TargetType="{x:Type controls:SystemRewireOverlay}">
        <Setter Property="Template" Value="{StaticResource SystemRewireOverlayTemplate}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="AutomationProperties.Name" Value="System Rewire theme transition overlay" />
    </Style>
</ResourceDictionary>
