<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:HardwareVision.Controls">
    <Style x:Key="TraceworkGameControlDeckStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkPanelStyle}">
        <Setter Property="PanelVariant" Value="Primary" />
        <Setter Property="MinHeight" Value="286" />
        <Setter Property="BadgeMinWidth" Value="80" />
        <Setter Property="BadgeHorizontalAlignment" Value="Right" />
        <Setter Property="BadgeVerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="TraceworkGameSectionStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkPanelStyle}">
        <Setter Property="PanelVariant" Value="Muted" />
        <Setter Property="MinHeight" Value="150" />
    </Style>

    <Style x:Key="TraceworkCaptureStatusStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkRowsBadgeStyle}">
        <Setter Property="MinWidth" Value="96" />
    </Style>

    <Style x:Key="TraceworkProcessSearchStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource SettingsInputBox}">
        <Setter Property="Height" Value="64" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="TraceworkProcessSelectorStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource TraceworkDeviceSelectorStyle}">
        <Setter Property="Height" Value="64" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MaxWidth" Value="10000" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False" />
                                <Border Grid.Column="1"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1,0,0,0">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="▼"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                        <ToggleButton Background="Transparent"
                                      BorderThickness="0"
                                      ClickMode="Press"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{DynamicResource CardBackgroundSoftBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TraceworkCaptureButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource FutureButton}">
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Margin" Value="0,0,8,8" />
    </Style>

    <Style x:Key="TraceworkTargetButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource TraceworkCaptureButtonStyle}">
        <Setter Property="Height" Value="64" />
        <Setter Property="MinWidth" Value="172" />
        <Setter Property="Margin" Value="0,0,16,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="TraceworkStopButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource TraceworkCaptureButtonStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource CriticalBrush}" />
    </Style>

    <Style x:Key="TraceworkTargetStopButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource TraceworkTargetButtonStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource CriticalBrush}" />
    </Style>

    <Style x:Key="TraceworkLiveMetricPanelStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkGameSectionStyle}">
        <Setter Property="MinHeight" Value="176" />
    </Style>

    <Style x:Key="TraceworkLiveMetricGridStyle" TargetType="ItemsControl">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="TraceworkLiveMetricStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkIdentityCardStyle}">
        <Setter Property="MinHeight" Value="62" />
    </Style>

    <Style x:Key="TraceworkGameChartCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkNodePanelStyle}">
        <Setter Property="MinHeight" Value="152" />
    </Style>

    <Style x:Key="TraceworkLimitEventStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkNodePanelStyle}" />

    <Style x:Key="TraceworkLimitReasonBadgeStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkRowsBadgeStyle}">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0,2,6,2" />
    </Style>

    <Style x:Key="TraceworkSessionArchiveStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkGameSectionStyle}">
        <Setter Property="MinHeight" Value="210" />
    </Style>

    <Style x:Key="TraceworkSessionRecordItemStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkNodePanelStyle}" />

    <Style x:Key="TraceworkSessionRecordListStyle" TargetType="ListBox">
        <Setter Property="MaxHeight" Value="420" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
    </Style>

    <Style x:Key="TraceworkSessionListItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TraceworkSessionPagingBarStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="TraceworkReportHeaderStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkPageHeaderStyle}" />

    <Style x:Key="TraceworkReportIdentityStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkGameControlDeckStyle}" />

    <Style x:Key="TraceworkReportTimelineStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkGameSectionStyle}" />

    <Style x:Key="TraceworkReportMetricStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkIdentityCardStyle}">
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="MinHeight" Value="60" />
    </Style>

    <Style x:Key="TraceworkReportChartStyle"
           TargetType="controls:TraceworkPanel"
           BasedOn="{StaticResource TraceworkGameSectionStyle}">
        <Setter Property="MinHeight" Value="320" />
    </Style>

    <Style x:Key="TraceworkReportWarningStyle"
           TargetType="Border"
           BasedOn="{StaticResource TraceworkNodePanelStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
    </Style>

    <Style x:Key="TraceworkGameIconFrameStyle" TargetType="Border">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style x:Key="TraceworkReportPathStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource TraceworkPathValueStyle}">
        <Setter Property="MaxWidth" Value="620" />
    </Style>
</ResourceDictionary>
