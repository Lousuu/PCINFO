<UserControl x:Class="HardwareVision.Views.Motherboard.TraceworkMotherboardLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <DataTemplate x:Key="BoardMetricCellTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <Border ToolTip="{Binding ToolTip}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource TraceworkIdentityCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" ToolTip="{Binding LabelToolTip}" Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                    <TextBlock Text="{Binding Value, TargetNullValue=--, FallbackValue=--}" ToolTip="{Binding ValueToolTip}" Style="{DynamicResource TraceworkIdentityValueStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="TraceworkMotherboardScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{DynamicResource RetroPageStackStyle}">
            <Border Style="{DynamicResource TraceworkPageHeaderStyle}">
                <StackPanel>
                    <TextBlock Text="BRD.01 / BOARD FABRIC" Style="{DynamicResource TraceworkPageCodeTextStyle}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding MotherboardName}" ToolTip="{Binding MotherboardName}" Style="{DynamicResource TraceworkPageTitleTextStyle}" />
                    <TextBlock Margin="0,3,0,0" Text="主板、固件、设备结构与传感器总线" Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                </StackPanel>
            </Border>

            <UniformGrid Columns="3">
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="DEVICE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding DeviceSummary}" ToolTip="{Binding DeviceSummary}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="SENSORS" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding SensorRows.Count}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="BUS" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding HasMotherboardSensors}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
            </UniformGrid>

            <UniformGrid Columns="2">
                <controls:TraceworkPanel Code="BRD.10"
                                         Title="BOARD IDENTITY"
                                         Subtitle="主板与整机标识"
                                         HeaderNote="WMI IDENTITY"
                                         BadgeText="{Binding BoardProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         Margin="0,0,8,8"
                                         Style="{DynamicResource TraceworkHeroPanelStyle}">
                    <ItemsControl ItemsSource="{Binding BoardProjection.VisibleMetrics}" ItemTemplate="{StaticResource BoardMetricCellTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </controls:TraceworkPanel>

                <controls:TraceworkPanel Code="BRD.15"
                                         Title="FIRMWARE"
                                         Subtitle="BIOS 与 UEFI 信息"
                                         HeaderNote="REPORTED FIRMWARE"
                                         BadgeText="{Binding BiosProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         Margin="0,0,0,8"
                                         Style="{DynamicResource TraceworkSecondaryPanelStyle}">
                    <ItemsControl ItemsSource="{Binding BiosProjection.VisibleMetrics}" ItemTemplate="{StaticResource BoardMetricCellTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </controls:TraceworkPanel>
            </UniformGrid>

            <controls:TraceworkPanel Code="BRD.20"
                                     Title="SYSTEM CHASSIS"
                                     Subtitle="设备类型与机箱信息"
                                     HeaderNote="EXISTING INFERENCE"
                                     BadgeText="{Binding DeviceProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                     Style="{DynamicResource TraceworkPanelStyle}">
                <ItemsControl ItemsSource="{Binding DeviceProjection.VisibleMetrics}" ItemTemplate="{StaticResource BoardMetricCellTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </controls:TraceworkPanel>

            <controls:TraceworkPanel Code="BRD.30"
                                     Title="SENSOR BUS"
                                     Subtitle="主板传感器与控制器读数"
                                     HeaderNote="LIVE SENSOR ROWS"
                                     BadgeText="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                     Style="{DynamicResource TraceworkDataTablePanelStyle}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <ItemsControl ItemsSource="{Binding SensorProjection.VisibleMetrics}" ItemTemplate="{StaticResource BoardMetricCellTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Border Grid.Row="1" Style="{DynamicResource TraceworkDividerStyle}" />
                    <DataGrid x:Name="MotherboardSensorGrid"
                              Grid.Row="2"
                              MaxHeight="300"
                              ItemsSource="{Binding SensorRows}"
                              Style="{DynamicResource TraceworkDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="名称" Width="2*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" ToolTip="{Binding NameToolTip}" Style="{DynamicResource TraceworkSensorNameTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="类型" Width="2*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding DisplayType}" ToolTip="{Binding TypeToolTip}" Style="{DynamicResource TraceworkSensorTypeTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="读数" Width="*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Readout}" ToolTip="{Binding ReadoutToolTip}" Style="{DynamicResource TraceworkSensorValueTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="状态" Width="*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Availability}" ToolTip="{Binding FullToolTip}" Style="{DynamicResource TraceworkSensorStatusTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="3" Margin="0,8,0,0" Visibility="{Binding NoSensorData, Converter={StaticResource BoolToVisibilityConverter}}" Style="{DynamicResource TraceworkEmptyStateStyle}">
                        <TextBlock Text="当前没有可显示的主板传感器数据" Style="{DynamicResource TraceworkEmptyStateTextStyle}" />
                    </Border>
                </Grid>
            </controls:TraceworkPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
