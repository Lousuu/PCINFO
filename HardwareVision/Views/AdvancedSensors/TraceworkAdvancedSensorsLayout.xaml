<UserControl x:Class="HardwareVision.Views.AdvancedSensors.TraceworkAdvancedSensorsLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             Background="{DynamicResource AppBackgroundBrush}">
    <Grid Style="{DynamicResource RetroPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{DynamicResource TraceworkPageHeaderStyle}">
            <StackPanel>
                <TextBlock Text="SNS.01 / SENSOR MATRIX"
                           Style="{DynamicResource TraceworkPageCodeTextStyle}" />
                <TextBlock Margin="0,4,0,0"
                           Text="原始传感器读数与可用性"
                           Style="{DynamicResource TraceworkPageTitleTextStyle}" />
                <TextBlock Margin="0,3,0,0"
                           Text="原始硬件通道、当前读数与可用性状态"
                           Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4">
            <Border Style="{DynamicResource TraceworkDataStripStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="STATE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" ToolTip="{Binding StatusText}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                </Grid>
            </Border>
            <Border Style="{DynamicResource TraceworkDataStripStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="VISIBLE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                    <TextBlock Grid.Column="1" Text="{Binding SensorRows.Count}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                </Grid>
            </Border>
            <Border Style="{DynamicResource TraceworkDataStripStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="LIMIT" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                    <TextBlock Grid.Column="1" Text="500 MAX" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                </Grid>
            </Border>
            <Border Style="{DynamicResource TraceworkDataStripStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="THROTTLE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                    <TextBlock Grid.Column="1" Text="3 SEC" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                </Grid>
            </Border>
        </UniformGrid>

        <controls:TraceworkPanel Grid.Row="2"
                                 Code="SNS.10"
                                 Title="RAW CHANNELS"
                                 Subtitle="当前页面可见的传感器读数"
                                 HeaderNote="LIVE MATRIX"
                                 BadgeText="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                 Style="{DynamicResource TraceworkDataTablePanelStyle}">
            <DataGrid ItemsSource="{Binding SensorRows}"
                      Style="{DynamicResource TraceworkDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="名称" Width="1.5*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" Style="{DynamicResource TraceworkSensorNameTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="技术名" Width="2.5*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding DisplayType}" ToolTip="{Binding DisplayType}" Style="{DynamicResource TraceworkSensorTypeTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="读数" Width="1*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Readout}" Style="{DynamicResource TraceworkSensorValueTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="状态" Width="1*" HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}" HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Availability}" Style="{DynamicResource TraceworkSensorStatusTextStyle}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </controls:TraceworkPanel>
    </Grid>
</UserControl>
