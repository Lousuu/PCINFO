<UserControl x:Class="HardwareVision.Views.GamePerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:GamePerformanceViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource RetroPageStackStyle}">
            <Border Style="{StaticResource SensorRow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="游戏性能" Style="{StaticResource MetricLabelText}" />
                            <TextBlock Text="{Binding StatusText}"
                                       TextTrimming="CharacterEllipsis"
                                       Style="{StaticResource SectionTitleText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Content="刷新"
                                Command="{Binding RefreshProcessesCommand}"
                                Style="{StaticResource FutureButton}" />
                    </Grid>

                    <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                        <Grid Width="230" Margin="0,0,8,8">
                            <TextBox x:Name="ProcessSearchBox"
                                     HorizontalContentAlignment="Left"
                                     IsEnabled="{Binding CanSelectProcess}"
                                     Style="{StaticResource SettingsInputBox}"
                                     Text="{Binding ProcessSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="10,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Text="搜索游戏、窗口标题或进程名"
                                       Foreground="{StaticResource TextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=ProcessSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ComboBox Width="350"
                                  Margin="0,0,8,8"
                                  VerticalAlignment="Center"
                                  IsEnabled="{Binding CanSelectProcess}"
                                  ItemsSource="{Binding ProcessOptions}"
                                  SelectedItem="{Binding SelectedProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource FutureComboBox}"
                                  TextSearch.TextPath="DisplayName">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GameProcessInfo}">
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ToolTip}"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Margin="0,0,8,8"
                                Content="识别游戏"
                                Command="{Binding DetectGameCommand}"
                                Style="{StaticResource FutureButton}" />
                        <Button Margin="0,0,8,8"
                                Content="开始"
                                Command="{Binding StartCaptureCommand}"
                                Style="{StaticResource FutureButton}" />
                        <Button Margin="0,0,0,8"
                                Content="停止"
                                Command="{Binding StopCaptureCommand}"
                                Style="{StaticResource FutureButton}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="完整会话记录" Style="{StaticResource MetricLabelText}" />
                            <CheckBox Margin="0,6,0,0"
                                      Content="自动记录游戏会话"
                                      IsChecked="{Binding AutoRecordGameSessions}"
                                      Style="{StaticResource ToggleSwitch}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="打开记录目录"
                                Command="{Binding OpenRecordingDirectoryCommand}"
                                Style="{StaticResource FutureButton}" />
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding RecordingStatusText}" Style="{StaticResource BodyText}" />
                            <TextBlock Text="{Binding RecordingCurrentPath}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding RecordingCurrentPath}"
                                       Style="{StaticResource CaptionText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Content="定位当前文件"
                                Command="{Binding OpenCurrentRecordingCommand}"
                                Visibility="{Binding HasRecordingCurrentPath, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{StaticResource FutureButton}" />
                    </Grid>
                </Grid>
            </Border>

            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility"
                                Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                        <Border Margin="0,0,8,8"
                                ToolTip="{Binding ToolTip}"
                                Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource MetricLabelText}" />
                                <TextBlock Text="{Binding Value}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource MetricValueText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Margin="0,6,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="实时曲线" Style="{StaticResource SectionTitleText}" />
                        <ComboBox Grid.Column="1"
                                  Width="104"
                                  ItemsSource="{Binding ChartWindowOptions}"
                                  SelectedItem="{Binding SelectedChartWindowSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DashboardHardwareComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0}s}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <WrapPanel Grid.Column="2"
                                   Margin="8,0,0,0"
                                   Visibility="{Binding ShowManualExport, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Margin="0,0,8,0"
                                    Content="导出当前窗口"
                                    Command="{Binding ExportCurrentWindowCommand}"
                                    Style="{StaticResource FutureButton}" />
                            <Button Content="保存当前缓存"
                                    Command="{Binding ExportCacheCommand}"
                                    Style="{StaticResource FutureButton}" />
                        </WrapPanel>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Charts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:RealtimeMetricChartViewModel}">
                                <Border Margin="0,0,8,8" Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="92" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource MetricLabelText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CurrentText}"
                                                       Style="{StaticResource BodyText}" />
                                        </Grid>
                                        <controls:RealtimeLineChart Grid.Row="1"
                                                                    Margin="0,5,0,4"
                                                                    Values="{Binding Values}"
                                                                    HasData="{Binding HasData}"
                                                                    MinimumValue="{Binding MinimumValue}"
                                                                    MaximumValue="{Binding MaximumValue}"
                                                                    LineBrush="{StaticResource AccentBrush}"
                                                                    GridLineBrush="{StaticResource DividerBrush}"
                                                                    TextBrush="{StaticResource TextMutedBrush}"
                                                                    EmptyText="--" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding AverageText, StringFormat={}AVG {0}}" Style="{StaticResource CaptionText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding MinimumText, StringFormat={}MIN {0}}"
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource CaptionText}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding MaximumText, StringFormat={}MAX {0}}"
                                                       HorizontalAlignment="Right"
                                                       Style="{StaticResource CaptionText}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Expander Margin="0,10,0,0" Header="最近记录（最多 10 条）">
                <ItemsControl ItemsSource="{Binding RecentRecords}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:GameSessionRecordInfo}">
                            <Border Margin="0,0,0,6" Style="{StaticResource SensorRow}" ToolTip="{Binding CsvPath}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding GameName}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding StartedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource CaptionText}" />
                                    <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="{Binding DurationText}" Style="{StaticResource CaptionText}" />
                                    <TextBlock Grid.Column="3" Margin="12,0,0,0" Text="{Binding StatusText}" Style="{StaticResource CaptionText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
