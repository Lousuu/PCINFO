<UserControl x:Class="HardwareVision.Views.GamePerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layouts="clr-namespace:HardwareVision.Views.GamePerformance"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:themes="clr-namespace:HardwareVision.Themes"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             xmlns:views="clr-namespace:HardwareVision.Views"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <DataTemplate x:Key="ClassicGamePerformanceTemplate">
            <layouts:ClassicGamePerformanceLayout />
        </DataTemplate>
        <DataTemplate x:Key="TraceworkGamePerformanceTemplate">
            <layouts:TraceworkGamePerformanceLayout />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ContentControl x:Name="CaptureWorkspaceHost"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Content="{Binding}"
                        Visibility="{Binding HasNoSessionReport, Converter={StaticResource BoolToVisibilityConverter}}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource ClassicGamePerformanceTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=(themes:ThemeContext.CurrentTheme), RelativeSource={RelativeSource Self}}"
                                     Value="{x:Static models:AppTheme.Tracework}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TraceworkGamePerformanceTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <ContentControl x:Name="SessionReportHost"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Content="{Binding SessionReport}"
                        Visibility="{Binding HasSessionReport, Converter={StaticResource BoolToVisibilityConverter}}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type viewModels:GameSessionReportViewModel}">
                    <views:GameSessionReportView />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</UserControl>
