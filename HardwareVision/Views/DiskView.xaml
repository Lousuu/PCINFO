<UserControl x:Class="HardwareVision.Views.DiskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DiskViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="存储" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="硬盘 / 存储设备" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="多硬盘独立展示，静态信息低频更新，温度与读写状态随传感器刷新。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource StatusBadge}">
                        <TextBlock Text="{Binding DiskDevices.Count, StringFormat={}{0} DISKS}"
                                   Style="{StaticResource BadgeText}" />
                    </Border>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="硬盘总览" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="容量与系统盘来自 WMI，最高温度来自 LibreHardwareMonitor，健康状态优先使用存储子系统报告。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding OverviewMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource MetricValueText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <ItemsControl Margin="0,20,0,0" ItemsSource="{Binding DiskDevices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:DiskDeviceViewModel}">
                        <Border Margin="0,0,0,18" Style="{StaticResource MetricCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource SectionTitleText}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Subtitle}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource SectionSubtitleText}" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource StatusBadge}">
                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource BadgeText}" />
                                    </Border>
                                </Grid>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility"
                                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="5" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                            <Border Margin="0,0,12,12"
                                                    ToolTip="{Binding ToolTip}"
                                                    Style="{StaticResource SensorRow}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding Value}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{StaticResource BodyText}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Text="{Binding Source}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{StaticResource CaptionText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Grid.Row="4" Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="专业信息" Style="{StaticResource MetricLabelText}" />
                                            <TextBlock Text="序列号默认隐藏；功耗传感器不可用时保持 --，不使用 0 代替。"
                                                       Style="{StaticResource CaptionText}" />
                                        </StackPanel>

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding ProfessionalMetrics}">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Visibility"
                                                            Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                                    <Border Margin="0,0,12,12"
                                                            ToolTip="{Binding ToolTip}"
                                                            Style="{StaticResource SensorRow}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Text="{Binding Value}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource BodyText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
