<UserControl x:Class="HardwareVision.Views.GpuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:GpuViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource RetroPageStackStyle}">
            <Border Style="{StaticResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding GpuName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding GpuNameToolTip}"
                                   Style="{StaticResource SectionTitleText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                MinWidth="260"
                                HorizontalAlignment="Right">
                        <TextBlock Text="当前 GPU" Style="{StaticResource MetricLabelText}" />
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding GpuDevices}"
                                  SelectedItem="{Binding SelectedGpu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource FutureComboBox}"
                                  TextSearch.TextPath="Name">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GpuDevice}">
                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuMetrics, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="GPU 总览" Style="{StaticResource SectionTitleText}" />

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,8,8"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource MetricValueText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="详细信息" Style="{StaticResource SectionTitleText}" />

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding InfoItems}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,8,8"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuSensors, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{StaticResource RetroDataTableCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Style="{StaticResource RetroTableHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Text="传感器"
                                   Style="{StaticResource SectionTitleText}" />
                        <Border Grid.Column="1"
                                Style="{StaticResource RetroRowsBadgeStyle}">
                            <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                       Style="{StaticResource RetroRowsBadgeTextStyle}" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              MaxHeight="320"
                              ItemsSource="{Binding SensorRows}"
                              Style="{StaticResource RetroSensorDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称"
                                                Binding="{Binding DisplayName}"
                                                Width="1.6*"
                                                MinWidth="160"
                                                HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                                ElementStyle="{StaticResource SensorTableNameTextStyle}" />
                            <DataGridTextColumn Header="技术名"
                                                Binding="{Binding DisplayType}"
                                                Width="2.6*"
                                                MinWidth="220"
                                                HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                                ElementStyle="{StaticResource SensorTableTypeTextStyle}" />
                            <DataGridTextColumn Header="读数"
                                                Binding="{Binding Readout}"
                                                Width="1*"
                                                MinWidth="120"
                                                HeaderStyle="{StaticResource SensorTableHeaderRightStyle}"
                                                ElementStyle="{StaticResource SensorTableReadoutTextStyle}" />
                            <DataGridTextColumn Header="状态"
                                                Binding="{Binding Availability}"
                                                Width="0.9*"
                                                MinWidth="95"
                                                HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                                ElementStyle="{StaticResource SensorTableStatusTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
