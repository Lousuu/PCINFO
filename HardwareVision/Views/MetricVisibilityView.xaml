<UserControl x:Class="HardwareVision.Views.MetricVisibilityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:MetricVisibilityViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SensorRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="显示项管理" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="选择每个硬件页面显示哪些核心指标和专业指标。"
                               Style="{StaticResource SectionSubtitleText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="恢复默认"
                            Command="{Binding RestoreDefaultsCommand}"
                            Style="{StaticResource FutureButton}" />
                    <Button Margin="10,0,0,0"
                            Content="显示全部专业指标"
                            Command="{Binding ShowAllProfessionalCommand}"
                            Style="{StaticResource FutureButton}" />
                    <Button Margin="10,0,0,0"
                            Content="仅显示核心指标"
                            Command="{Binding ShowCoreOnlyCommand}"
                            Style="{StaticResource FutureButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="硬件分类" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource CaptionText}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MetricVisibilityCategoryViewModel}">
                                <Button Margin="0,0,0,8"
                                        Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SidebarButton}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Title}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Summary}"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCategory.Title}" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="未配置过的指标使用默认显示策略；读取不到的数据仍显示 --。"
                                       Style="{StaticResource SectionSubtitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StatusBadge}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding VisibleMetrics.Count, StringFormat={}{0} ITEMS}"
                                       Style="{StaticResource BadgeText}" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,2,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="显示" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Grid.Column="1" Text="中文名称" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Grid.Column="2" Text="技术名" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Grid.Column="3" Text="单位" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Grid.Column="4" Text="来源" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Grid.Column="5" Text="说明" Style="{StaticResource MetricLabelText}" />
                    </Grid>

                    <ScrollViewer Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="True">
                        <ItemsControl ItemsSource="{Binding VisibleMetrics}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:MetricVisibilityItemViewModel}">
                                    <Border Margin="0,0,0,8"
                                            ToolTip="{Binding Id}"
                                            Style="{StaticResource SensorRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.25*" />
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1.5*" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Content="显示"
                                                      IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ToggleSwitch}" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource BodyText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding ImportanceText}"
                                                           Style="{StaticResource CaptionText}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding TechnicalName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource BodyText}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Unit}"
                                                       Style="{StaticResource BodyText}" />
                                            <TextBlock Grid.Column="4"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Source}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource BodyText}" />
                                            <TextBlock Grid.Column="5"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource CaptionText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
