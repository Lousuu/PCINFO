<UserControl x:Class="HardwareVision.Views.GameSessionReport.ClassicGameSessionReportLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{DynamicResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:GameSessionReportViewModel, IsDesignTimeCreatable=False}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{DynamicResource RetroPageStackStyle}">
            <Border Style="{DynamicResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Width="76" Margin="0,0,10,0" Content="← 返回" Command="{Binding BackCommand}" Style="{DynamicResource FutureButton}" />
                    <Grid Grid.Column="1" Width="54" Height="54" Margin="0,0,12,0">
                        <Border Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1.5"
                                CornerRadius="9">
                            <TextBlock Text="{Binding GameInitial}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding HasNoGameIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Border>
                        <Image Width="46" Height="46" Source="{Binding GameIcon}"
                               Visibility="{Binding HasGameIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameName}" Style="{DynamicResource SectionTitleText}" />
                        <TextBlock Margin="0,3,0,0" Text="{Binding ProcessName, StringFormat=进程：{0}}" Style="{DynamicResource CaptionText}" />
                        <TextBlock Text="{Binding SessionDiagnostic}" ToolTip="{Binding SessionDiagnostic}" TextTrimming="CharacterEllipsis" Style="{DynamicResource CaptionText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                        <Border Style="{DynamicResource StatusBadge}">
                            <TextBlock Text="{Binding SessionStatusText}" Style="{DynamicResource BadgeText}" />
                        </Border>
                        <Button Margin="0,8,0,0" Content="打开记录目录" Command="{Binding OpenDirectoryCommand}" Style="{DynamicResource FutureButton}" />
                        <Button Margin="0,8,0,0"
                                Content="导出普通 CSV"
                                Command="{Binding ExportPlainCsvCommand}"
                                Visibility="{Binding IsCompressedFrameRecord, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{DynamicResource FutureButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,8,0,0" Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="开始时间" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding StartedAtText}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="结束时间" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding EndedAtText}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="会话时长" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding DurationText}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="结束原因" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding EndReasonText}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,8,0,0" Style="{DynamicResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}" Style="{DynamicResource BodyText}" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding RecordDirectory}" TextTrimming="CharacterEllipsis" Style="{DynamicResource CaptionText}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="历史会话报告 · 非实时数据" VerticalAlignment="Center" Style="{DynamicResource CaptionText}" />
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="性能统计" Style="{DynamicResource SectionTitleText}" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding KeyMetrics}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GameSessionReportMetric}">
                                <Border Width="190" MinHeight="62" Margin="0,0,8,8" ToolTip="{Binding ToolTip}" Style="{DynamicResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{DynamicResource MetricLabelText}" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Value}" TextTrimming="CharacterEllipsis" Style="{DynamicResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="会话性能曲线" Style="{DynamicResource SectionTitleText}" />
                            <TextBlock Margin="0,3,0,0" Text="横轴为会话经过时间；橙红背景表示明确的硬件限制事件区间" Style="{DynamicResource CaptionText}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  MinWidth="160"
                                  MaxWidth="320"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Charts}"
                                  SelectedItem="{Binding SelectedChart, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  Style="{DynamicResource DashboardHardwareComboBox}" />
                    </Grid>
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="{Binding SelectedChart.Title}" Style="{DynamicResource BodyText}" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding SelectedChart.Subtitle}" TextWrapping="Wrap" Style="{DynamicResource CaptionText}" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding SelectedChart.SampleNotice}" TextWrapping="Wrap" Style="{DynamicResource CaptionText}" />
                    </StackPanel>
                    <controls:SessionTelemetryChart Grid.Row="2"
                                                    Margin="0,8,0,0"
                                                    Model="{Binding SelectedChart}"
                                                    PrimaryLineBrush="{DynamicResource AccentBrush}"
                                                    SecondaryLineBrush="{DynamicResource SuccessBrush}"
                                                    TertiaryLineBrush="{DynamicResource WarningBrush}"
                                                    GridLineBrush="{DynamicResource DividerBrush}"
                                                    TextBrush="{DynamicResource TextMutedBrush}"
                                                    LimitBrush="{DynamicResource CriticalBrush}" />
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="CPU / GPU 性能限制统计" Style="{DynamicResource SectionTitleText}" />
                    <TextBlock Margin="0,3,0,0" Text="仅由明确硬件限制状态标记；覆盖不足的频率统计显示 --" Style="{DynamicResource CaptionText}" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ThrottleMetrics}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GameSessionReportMetric}">
                                <Border Width="238" MinHeight="60" Margin="0,0,8,8" ToolTip="{Binding ToolTip}" Style="{DynamicResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{DynamicResource MetricLabelText}" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Value}" TextTrimming="CharacterEllipsis" Style="{DynamicResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="性能限制事件" Style="{DynamicResource SectionTitleText}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding PerformanceLimitStatusText}" Style="{DynamicResource CaptionText}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{DynamicResource StatusBadge}">
                            <TextBlock Text="{Binding TimelineStatusText}" Style="{DynamicResource BadgeText}" />
                        </Border>
                    </Grid>
                    <TextBlock Margin="0,10,0,0"
                               Text="未检测到性能限制事件"
                               Visibility="{Binding HasNoPerformanceLimitEvents, Converter={StaticResource BoolToVisibilityConverter}}"
                               Style="{DynamicResource CaptionText}" />
                    <ListBox Margin="0,10,0,0"
                             MaxHeight="420"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ItemsSource="{Binding PerformanceLimitEvents}"
                             Visibility="{Binding HasPerformanceLimitEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GamePerformanceLimitEvent}">
                                <Border Margin="0,0,0,6" Style="{DynamicResource SensorRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" /><ColumnDefinition Width="64" /><ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" /><ColumnDefinition Width="105" /><ColumnDefinition Width="95" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}" Style="{DynamicResource BodyText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ProcessorText}" Style="{DynamicResource BodyText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding DurationText}" Style="{DynamicResource CaptionText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding ReasonText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding RawReasonText}" Style="{DynamicResource CaptionText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding TriggerCountText}" Style="{DynamicResource CaptionText}" />
                                        <TextBlock Grid.Column="5" Text="{Binding MergeText}" Style="{DynamicResource CaptionText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="会话硬件信息" Style="{DynamicResource SectionTitleText}" />
                    <TextBlock Margin="0,3,0,0" Text="来自会话开始时保存的历史元数据和会话积分，不读取当前机器状态冒充历史值" Style="{DynamicResource CaptionText}" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding HardwareMetrics}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GameSessionReportMetric}">
                                <Border Width="238" MinHeight="60" Margin="0,0,8,8" ToolTip="{Binding Value}" Style="{DynamicResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{DynamicResource MetricLabelText}" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Value}" TextTrimming="CharacterEllipsis" Style="{DynamicResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="数据完整性" Style="{DynamicResource SectionTitleText}" />
                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Style="{DynamicResource CaptionText}" /></DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
