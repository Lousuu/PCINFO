<UserControl x:Class="HardwareVision.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:MemoryViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SensorRow}">
                <StackPanel>
                    <TextBlock Text="内存" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Text="物理内存、虚拟内存、内存条与平台能力"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Speed 是标称或模块速度；ConfiguredClockSpeed 是当前配置频率，不代表实时频率。"
                               Style="{StaticResource SectionSubtitleText}" />
                </StackPanel>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="内存总览" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="物理内存使用率随传感器刷新；虚拟内存来自 Windows API。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding OverviewMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetricValueText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="内存条列表" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="来自 WMI Win32_PhysicalMemory；只在启动或手动刷新硬件信息时更新。"
                                       Style="{StaticResource SectionSubtitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StatusBadge}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding MemoryModules.Count, StringFormat={}{0} MODULES}"
                                       Style="{StaticResource BadgeText}" />
                        </Border>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding MemoryModules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MemoryModuleViewModel}">
                                <Border Margin="0,0,0,14" Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding SlotName}" Style="{StaticResource MetricLabelText}" />
                                                <TextBlock Text="{Binding ModuleName}" Style="{StaticResource BodyText}" />
                                            </StackPanel>
                                        </Grid>

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Visibility"
                                                            Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                                    <Border Margin="0,0,12,12"
                                                            ToolTip="{Binding ToolTip}"
                                                            Style="{StaticResource SensorRow}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Text="{Binding Value}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource BodyText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="专业信息" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="通道数仅在可较可靠推断时显示；功耗缺失时保持 --。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ProfessionalMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
