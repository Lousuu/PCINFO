<UserControl x:Class="HardwareVision.Views.Memory.TraceworkMemoryLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Style="{DynamicResource TraceworkPageRootStyle}"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="MemoryModuleMetricContainerStyle" TargetType="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Style>
        <DataTemplate x:Key="MemoryMetricCellTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <Border ToolTip="{Binding ToolTip}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource TraceworkIdentityCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               ToolTip="{Binding LabelToolTip}"
                               Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                    <TextBlock Text="{Binding Value, TargetNullValue=--, FallbackValue=--}"
                               ToolTip="{Binding ValueToolTip}"
                               Style="{DynamicResource TraceworkIdentityValueStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MemoryModuleMetricCellTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <ContentControl ToolTip="{Binding Value}"
                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{DynamicResource TraceworkMemoryMetricCardStyle}">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Left"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               ToolTip="{Binding Label}"
                               Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Left"
                               Text="{Binding Value, TargetNullValue=--, FallbackValue=--}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               ToolTip="{Binding Value}"
                               Style="{DynamicResource TraceworkIdentityValueStyle}" />
                </StackPanel>
            </ContentControl>
        </DataTemplate>
        <DataTemplate x:Key="MemoryMetricRowTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <Grid Margin="0,0,12,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Label}"
                           ToolTip="{Binding LabelToolTip}"
                           Style="{DynamicResource TraceworkMetricRowLabelStyle}" />
                <TextBlock Grid.Column="1"
                           Margin="8,0,0,0"
                           Text="{Binding Value, TargetNullValue=--, FallbackValue=--}"
                           ToolTip="{Binding ValueToolTip}"
                           Style="{DynamicResource TraceworkMetricRowValueStyle}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="TraceworkMemoryScrollViewer"
                  Style="{DynamicResource TraceworkPageScrollViewerStyle}">
        <StackPanel Style="{DynamicResource TraceworkPageContentStackStyle}">
            <Border Style="{DynamicResource TraceworkPageHeaderStyle}">
                <StackPanel>
                    <TextBlock Text="MEM.01 / MEMORY FABRIC" Style="{DynamicResource TraceworkPageCodeTextStyle}" />
                    <TextBlock Margin="0,4,0,0" Text="MEMORY TOPOLOGY" Style="{DynamicResource TraceworkPageTitleTextStyle}" />
                    <TextBlock Margin="0,3,0,0" Text="物理内存、提交容量与模组拓扑" Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                </StackPanel>
            </Border>

            <UniformGrid Columns="3">
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="CHANNELS" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding OverviewMetrics.Count}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="MODULES" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding MemoryModules.Count}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="PROFILE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding HasMemoryModules}" Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
            </UniformGrid>

            <controls:TraceworkResponsiveGrid x:Name="MemoryTopologyGrid"
                                              ColumnGap="18"
                                              RowGap="24">
                <controls:TraceworkPanel x:Name="MemoryCapacityField"
                                         Code="MEM.10"
                                         Title="CAPACITY FIELD"
                                         controls:NavigationMotion.Role="Primary"
                                         Subtitle="物理内存与提交容量"
                                         HeaderNote="VISIBLE METRICS"
                                         BadgeText="{Binding OverviewProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         controls:TraceworkResponsiveGrid.WideColumnSpan="7"
                                         controls:TraceworkResponsiveGrid.StandardColumnSpan="5"
                                         controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                         controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                         Style="{DynamicResource TraceworkHeroPanelStyle}">
                    <Border Style="{DynamicResource TraceworkCapacityFieldStyle}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding OverviewProjection.PrimaryMetric.Label, TargetNullValue=--, FallbackValue=--}"
                                       ToolTip="{Binding OverviewProjection.PrimaryMetric.LabelToolTip}"
                                       Style="{DynamicResource TraceworkHeroMetricLabelStyle}" />
                            <TextBlock Text="{Binding OverviewProjection.PrimaryMetric.Value, TargetNullValue=--, FallbackValue=--}"
                                       ToolTip="{Binding OverviewProjection.PrimaryMetric.ValueToolTip}"
                                       Style="{DynamicResource TraceworkHeroMetricValueStyle}" />
                        </StackPanel>
                        <Border Grid.Row="1" Style="{DynamicResource TraceworkDividerStyle}" />
                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding OverviewProjection.SecondaryMetrics}"
                                      ItemTemplate="{StaticResource MemoryMetricRowTemplate}" />
                    </Grid>
                    </Border>
                </controls:TraceworkPanel>

                <controls:TraceworkPanel Code="MEM.15"
                                         Title="SLOT / CHANNEL PROFILE"
                                         Subtitle="内存阵列与配置参数"
                                         HeaderNote="REPORTED VALUES"
                                         BadgeText="{Binding ProfessionalProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         controls:TraceworkResponsiveGrid.WideColumn="7"
                                         controls:TraceworkResponsiveGrid.WideColumnSpan="5"
                                         controls:TraceworkResponsiveGrid.StandardColumn="5"
                                         controls:TraceworkResponsiveGrid.StandardColumnSpan="3"
                                         controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                         controls:TraceworkResponsiveGrid.CompactRow="1"
                                         controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                         controls:TraceworkResponsiveGrid.NarrowRow="1"
                                         Style="{DynamicResource TraceworkSecondaryPanelStyle}">
                    <ItemsControl ItemsSource="{Binding ProfessionalProjection.VisibleMetrics}"
                                  ItemTemplate="{StaticResource MemoryMetricCellTemplate}"
                                  Style="{DynamicResource TraceworkDenseMetricGridStyle}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </controls:TraceworkPanel>
            </controls:TraceworkResponsiveGrid>

            <controls:TraceworkPanel Code="MEM.20"
                                     Title="MODULE SPECIFICATION MATRIX"
                                     controls:NavigationMotion.Role="Secondary"
                                     Subtitle="已安装内存模组"
                                     HeaderNote="WMI MODULES"
                                     BadgeText="{Binding MemoryModules.Count, StringFormat={}{0} DIMM}"
                                     Style="{DynamicResource TraceworkPanelStyle}">
                <Grid>
                    <ItemsControl x:Name="MemoryModuleTopology"
                                  ItemsSource="{Binding MemoryModules}"
                                  Style="{DynamicResource TraceworkTopologyMatrixStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MemoryModuleViewModel}">
                                <Border Margin="0,0,0,12"
                                        Style="{DynamicResource TraceworkTopologyNodeStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="DIMM" Style="{DynamicResource TraceworkPanelCodeTextStyle}" />
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding SlotName}" ToolTip="{Binding SlotName}" Style="{DynamicResource TraceworkPanelTitleTextStyle}" />
                                                <TextBlock Text="{Binding ModuleName}" ToolTip="{Binding ModuleName}" Style="{DynamicResource TraceworkPanelSubtitleTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl Grid.Row="2"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding Metrics}"
                                                      ItemContainerStyle="{StaticResource MemoryModuleMetricContainerStyle}"
                                                      ItemTemplate="{StaticResource MemoryModuleMetricCellTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:AdaptiveUniformGrid MinItemWidth="280"
                                                                                  HorizontalGap="12"
                                                                                  VerticalGap="12"
                                                                                  MaximumColumns="3" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource TraceworkEmptyStateStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers><DataTrigger Binding="{Binding HasMemoryModules}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="未检测到可显示的内存模组信息" Style="{DynamicResource TraceworkEmptyStateTextStyle}" />
                    </Border>
                </Grid>
            </controls:TraceworkPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
