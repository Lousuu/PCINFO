<UserControl x:Class="HardwareVision.Views.CpuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:CpuViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource RetroPageStackStyle}">
            <Border Style="{StaticResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding CpuName}" Style="{StaticResource SectionTitleText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="核心 / 线程" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding CoreThreadSummary}" Style="{StaticResource BodyText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility"
                                Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                        <Border Margin="0,0,8,8"
                                ToolTip="{Binding ToolTip}"
                                Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                <TextBlock Text="{Binding Value}" Style="{StaticResource MetricValueText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Margin="0,6,0,0" Style="{StaticResource RetroDataTableCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Style="{StaticResource RetroTableHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock VerticalAlignment="Center"
                                       Text="每核心数据"
                                       Style="{StaticResource SectionTitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource RetroRowsBadgeStyle}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding CoreRows.Count, StringFormat={}{0} ROWS}"
                                       Style="{StaticResource RetroRowsBadgeTextStyle}" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              MaxHeight="300"
                              ItemsSource="{Binding CoreRows}"
                              Style="{StaticResource RetroSensorDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="名称"
                                                    Width="2*"
                                                    MinWidth="180"
                                                    HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                                    HeaderTemplate="{StaticResource SensorTableLeftHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SensorTableNameTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="类型"
                                                    Width="3*"
                                                    MinWidth="260"
                                                    HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                                    HeaderTemplate="{StaticResource SensorTableLeftHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayType}" Style="{StaticResource SensorTableTypeTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="读数"
                                                    Width="1*"
                                                    MinWidth="120"
                                                    HeaderStyle="{StaticResource SensorTableHeaderRightStyle}"
                                                    HeaderTemplate="{StaticResource SensorTableRightHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Readout}" Style="{StaticResource SensorTableReadoutTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
