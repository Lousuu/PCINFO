<UserControl x:Class="HardwareVision.Views.CpuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{DynamicResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:CpuViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{DynamicResource RetroPageStackStyle}">
            <Border Style="{DynamicResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="CPU" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding CpuName}" Style="{DynamicResource SectionTitleText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="核心 / 线程" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding CoreThreadSummary}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility"
                                Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                        <Border Margin="0,0,8,8"
                                ToolTip="{Binding ToolTip}"
                                Style="{DynamicResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" Style="{DynamicResource MetricLabelText}" />
                                <TextBlock Text="{Binding Value}" Style="{DynamicResource MetricValueText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Margin="0,6,0,0" Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="实时曲线" Style="{DynamicResource SectionTitleText}" />
                        <ComboBox Grid.Column="1"
                                  Width="104"
                                  ItemsSource="{Binding ChartWindowOptions}"
                                  SelectedItem="{Binding SelectedChartWindowSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource DashboardHardwareComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0}s}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Charts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:RealtimeMetricChartViewModel}">
                                <Border Margin="0,0,8,8" Style="{DynamicResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="86" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" Style="{DynamicResource MetricLabelText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CurrentText}"
                                                       Style="{DynamicResource BodyText}" />
                                        </Grid>
                                        <controls:RealtimeLineChart Grid.Row="1"
                                                                    Margin="0,5,0,4"
                                                                    Values="{Binding Values}"
                                                                    HasData="{Binding HasData}"
                                                                    MinimumValue="{Binding MinimumValue}"
                                                                    MaximumValue="{Binding MaximumValue}"
                                                                    LineBrush="{DynamicResource AccentBrush}"
                                                                    GridLineBrush="{DynamicResource DividerBrush}"
                                                                    TextBrush="{DynamicResource TextMutedBrush}"
                                                                    EmptyText="--" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding AverageText, StringFormat={}AVG {0}}" Style="{DynamicResource CaptionText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding MinimumText, StringFormat={}MIN {0}}"
                                                       HorizontalAlignment="Center"
                                                       Style="{DynamicResource CaptionText}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding MaximumText, StringFormat={}MAX {0}}"
                                                       HorizontalAlignment="Right"
                                                       Style="{DynamicResource CaptionText}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,6,0,0" Style="{DynamicResource RetroDataTableCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Style="{DynamicResource RetroTableHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock VerticalAlignment="Center"
                                       Text="每核心数据"
                                       Style="{DynamicResource SectionTitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{DynamicResource RetroRowsBadgeStyle}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding CoreRows.Count, StringFormat={}{0} ROWS}"
                                       Style="{DynamicResource RetroRowsBadgeTextStyle}" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              MaxHeight="300"
                              ItemsSource="{Binding CoreRows}"
                              Style="{DynamicResource RetroSensorDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="名称"
                                                    Width="2*"
                                                    MinWidth="180"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource SensorTableNameTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="类型"
                                                    Width="3*"
                                                    MinWidth="260"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayType}" Style="{DynamicResource SensorTableTypeTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="读数"
                                                    Width="1*"
                                                    MinWidth="120"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Readout}" Style="{DynamicResource SensorTableReadoutTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
