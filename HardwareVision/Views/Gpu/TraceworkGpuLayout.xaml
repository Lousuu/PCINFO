<UserControl x:Class="HardwareVision.Views.Gpu.TraceworkGpuLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Style="{DynamicResource TraceworkPageRootStyle}"
             Background="{DynamicResource AppBackgroundBrush}">
    <ScrollViewer x:Name="TraceworkGpuScrollViewer"
                  Style="{DynamicResource TraceworkPageScrollViewerStyle}">
        <StackPanel Style="{DynamicResource TraceworkPageContentStackStyle}">
        <controls:TraceworkResponsiveGrid x:Name="GpuRenderPipelineGrid"
                                          ColumnGap="18"
                                          RowGap="24">
            <Border Style="{DynamicResource TraceworkPageHeaderStyle}"
                    controls:TraceworkResponsiveGrid.WideColumnSpan="12"
                    controls:TraceworkResponsiveGrid.StandardColumnSpan="8"
                    controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                    controls:TraceworkResponsiveGrid.NarrowColumnSpan="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="GPU.01 / GRAPHICS SIGNAL"
                               Style="{DynamicResource TraceworkPageCodeTextStyle}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,4,0,0"
                               Text="RENDER PIPELINE"
                               Style="{DynamicResource TraceworkPageTitleTextStyle}" />
                    <TextBlock Grid.Row="2"
                               Margin="0,3,0,0"
                               Text="图形处理器状态与渲染遥测"
                               Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                </Grid>
            </Border>

            <UniformGrid Columns="4"
                         controls:TraceworkResponsiveGrid.WideColumnSpan="12"
                         controls:TraceworkResponsiveGrid.WideRow="1"
                         controls:TraceworkResponsiveGrid.StandardColumnSpan="8"
                         controls:TraceworkResponsiveGrid.StandardRow="1"
                         controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                         controls:TraceworkResponsiveGrid.CompactRow="1"
                         controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                         controls:TraceworkResponsiveGrid.NarrowRow="1">
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DEVICE" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GpuName}"
                                   ToolTip="{Binding GpuNameToolTip}"
                                   Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ADAPTERS" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GpuDevices.Count}"
                                   Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CHANNELS" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Metrics.Count}"
                                   Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
                <Border Style="{DynamicResource TraceworkDataStripStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WINDOW" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedChartWindowSeconds, StringFormat={}{0}s}"
                                   Style="{DynamicResource TraceworkDataStripValueStyle}" />
                    </Grid>
                </Border>
            </UniformGrid>

            <StackPanel x:Name="GpuSecondaryColumn"
                        controls:NavigationMotion.Role="Secondary"
                        controls:TraceworkResponsiveGrid.WideColumn="8"
                        controls:TraceworkResponsiveGrid.WideColumnSpan="4"
                        controls:TraceworkResponsiveGrid.WideRow="2"
                        controls:TraceworkResponsiveGrid.StandardColumn="5"
                        controls:TraceworkResponsiveGrid.StandardColumnSpan="3"
                        controls:TraceworkResponsiveGrid.StandardRow="2"
                        controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                        controls:TraceworkResponsiveGrid.CompactRow="2"
                        controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                        controls:TraceworkResponsiveGrid.NarrowRow="2">
            <Border Style="{DynamicResource TraceworkIdentityPlateStyle}">
                <StackPanel>
                    <TextBlock x:Name="GpuSelectorTitle"
                               Text="GPU SELECTOR"
                               ToolTip="GPU SELECTOR"
                               automation:AutomationProperties.Name="GPU SELECTOR"
                               Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                    <TextBlock x:Name="GpuSelectorDescription"
                               Margin="0,3,0,0"
                               Text="当前图形适配器"
                               ToolTip="当前图形适配器"
                               automation:AutomationProperties.Name="当前图形适配器"
                               Style="{DynamicResource TraceworkChartHeaderTextStyle}" />
                    <ComboBox x:Name="GpuDeviceSelector"
                                  Margin="0,10,0,0"
                                  MinWidth="0"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding GpuDevices}"
                                  SelectedItem="{Binding SelectedGpu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ToolTip="{Binding GpuSelectionHint}"
                                  automation:AutomationProperties.Name="当前图形适配器"
                                  Style="{DynamicResource TraceworkGpuSelectorFullWidthStyle}"
                                  TextSearch.TextPath="Name">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GpuDevice}">
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock x:Name="GpuSelectorHint"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Left"
                                   Text="{Binding GpuSelectionHint}"
                                   ToolTip="{Binding GpuSelectionHint}"
                                   TextWrapping="Wrap"
                                   automation:AutomationProperties.Name="{Binding GpuSelectionHint}"
                                   Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                </StackPanel>
            </Border>

            <controls:TraceworkPanel x:Name="GpuWideDeviceIdentity"
                                     Margin="0,24,0,0"
                                     Code="GPU.15"
                                     Title="DEVICE IDENTITY"
                                     Subtitle="当前适配器的设备身份与驱动信息"
                                     HeaderNote="READ ONLY"
                                     BadgeText="{Binding InfoProjection.VisibleMetricCount, StringFormat={}{0} FIELDS}">
                <controls:TraceworkPanel.Style>
                    <Style TargetType="controls:TraceworkPanel" BasedOn="{StaticResource TraceworkTechnicalPanelStyle}">
                        <Setter Property="Visibility" Value="{Binding HasGpuDetails, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentMode, ElementName=GpuRenderPipelineGrid}" Value="Compact">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentMode, ElementName=GpuRenderPipelineGrid}" Value="Narrow">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:TraceworkPanel.Style>
                <ItemsControl ItemsSource="{Binding InfoProjection.VisibleMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                            <Border Style="{DynamicResource TraceworkIdentityCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               ToolTip="{Binding LabelToolTip}"
                                               Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                                    <TextBlock Text="{Binding Value}"
                                               ToolTip="{Binding ValueToolTip}"
                                               Style="{DynamicResource TraceworkIdentityValueStyle}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:TraceworkPanel>
            </StackPanel>

            <StackPanel x:Name="GpuPrimaryColumn"
                        Grid.IsSharedSizeScope="True"
                        controls:NavigationMotion.Role="Primary"
                        controls:TraceworkResponsiveGrid.WideColumnSpan="8"
                        controls:TraceworkResponsiveGrid.WideRow="2"
                        controls:TraceworkResponsiveGrid.StandardColumnSpan="5"
                        controls:TraceworkResponsiveGrid.StandardRow="2"
                        controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                        controls:TraceworkResponsiveGrid.CompactRow="3"
                        controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                        controls:TraceworkResponsiveGrid.NarrowRow="3">
            <controls:TraceworkPanel Code="GPU.10"
                                     Title="RENDER TELEMETRY"
                                     Subtitle="渲染核心、显存与功耗主通道"
                                     HeaderNote="VISIBLE METRICS"
                                     BadgeText="{Binding MetricProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                     Visibility="{Binding HasGpuMetrics, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Style="{DynamicResource TraceworkHeroPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding MetricProjection.PrimaryMetric.Label, TargetNullValue=--, FallbackValue=--}"
                                       ToolTip="{Binding MetricProjection.PrimaryMetric.LabelToolTip}"
                                       Style="{DynamicResource TraceworkHeroMetricLabelStyle}" />
                            <TextBlock Text="{Binding MetricProjection.PrimaryMetric.Value, TargetNullValue=--, FallbackValue=--}"
                                       ToolTip="{Binding MetricProjection.PrimaryMetric.ValueToolTip}"
                                       Style="{DynamicResource TraceworkHeroMetricValueStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Bottom"
                                   Text="PRIMARY"
                                   Style="{DynamicResource TraceworkPortLabelStyle}" />
                    </Grid>

                    <Border Grid.Row="1" Style="{DynamicResource TraceworkDividerStyle}" />

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding MetricProjection.SecondaryMetrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:AdaptiveUniformGrid MaximumColumns="2"
                                                              MinItemWidth="280"
                                                              HorizontalGap="28"
                                                              VerticalGap="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="GpuMetricLabel" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="GpuMetricValue" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}"
                                               ToolTip="{Binding LabelToolTip}"
                                               Style="{DynamicResource TraceworkMetricRowLabelStyle}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Value}"
                                               ToolTip="{Binding ValueToolTip}"
                                               Style="{DynamicResource TraceworkMetricRowValueStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </controls:TraceworkPanel>

            <controls:TraceworkPanel x:Name="GpuPrimaryChartField"
                                     Code="GPU.20"
                                     Title="LIVE CHANNELS"
                                     Margin="0,24,0,0"
                                     Subtitle="实时曲线保持当前适配器与原始历史窗口"
                                     HeaderNote="30 / 60 / 120 SEC"
                                     BadgeText="{Binding Charts.Count, StringFormat={}{0} PLOTS}"
                                     Style="{DynamicResource TraceworkPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Text="SIGNAL WINDOW"
                                   Style="{DynamicResource TraceworkChartHeaderTextStyle}" />
                        <ComboBox x:Name="GpuChartWindowSelector"
                                  Grid.Column="1"
                                  ItemsSource="{Binding ChartWindowOptions}"
                                  SelectedItem="{Binding SelectedChartWindowSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource TraceworkChartWindowSelectorStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0}s}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding Charts}"
                                  Style="{DynamicResource TraceworkChartGridStyle}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:RealtimeMetricChartViewModel}">
                                <Border Style="{DynamicResource TraceworkChartCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="118" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}"
                                                       ToolTip="{Binding Title}"
                                                       Style="{DynamicResource TraceworkChartHeaderTextStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="10,0,0,0"
                                                       Text="{Binding CurrentText}"
                                                       Style="{DynamicResource TraceworkChartCurrentValueStyle}" />
                                        </Grid>
                                        <controls:RealtimeLineChart Grid.Row="1"
                                                                    Margin="0,7,0,5"
                                                                    Values="{Binding Values}"
                                                                    HasData="{Binding HasData}"
                                                                    MinimumValue="{Binding MinimumValue}"
                                                                    MaximumValue="{Binding MaximumValue}"
                                                                    LineBrush="{DynamicResource AccentBrush}"
                                                                    GridLineBrush="{DynamicResource DividerBrush}"
                                                                    TextBrush="{DynamicResource TextMutedBrush}"
                                                                    EmptyText="--" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding AverageText, StringFormat={}AVG {0}}"
                                                       Style="{DynamicResource TraceworkChartStatisticStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding MinimumText, StringFormat={}MIN {0}}"
                                                       Style="{DynamicResource TraceworkChartStatisticStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding MaximumText, StringFormat={}MAX {0}}"
                                                       Style="{DynamicResource TraceworkChartStatisticStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </controls:TraceworkPanel>
            </StackPanel>

            <controls:TraceworkPanel x:Name="GpuCompactDeviceIdentity"
                                     Code="GPU.15"
                                     Title="DEVICE IDENTITY"
                                     Subtitle="当前适配器的设备身份与驱动信息"
                                     HeaderNote="READ ONLY"
                                     BadgeText="{Binding InfoProjection.VisibleMetricCount, StringFormat={}{0} FIELDS}"
                                     controls:TraceworkResponsiveGrid.WideColumnSpan="12"
                                     controls:TraceworkResponsiveGrid.WideRow="3"
                                     controls:TraceworkResponsiveGrid.StandardColumnSpan="8"
                                     controls:TraceworkResponsiveGrid.StandardRow="3"
                                     controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                     controls:TraceworkResponsiveGrid.CompactRow="4"
                                     controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                     controls:TraceworkResponsiveGrid.NarrowRow="4">
                <controls:TraceworkPanel.Style>
                    <Style TargetType="controls:TraceworkPanel" BasedOn="{StaticResource TraceworkTechnicalPanelStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CurrentMode, ElementName=GpuRenderPipelineGrid}" Value="Compact" />
                                    <Condition Binding="{Binding HasGpuDetails}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CurrentMode, ElementName=GpuRenderPipelineGrid}" Value="Narrow" />
                                    <Condition Binding="{Binding HasGpuDetails}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:TraceworkPanel.Style>
                <ItemsControl ItemsSource="{Binding InfoProjection.VisibleMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                            <Border Style="{DynamicResource TraceworkIdentityCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               ToolTip="{Binding LabelToolTip}"
                                               Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                                    <TextBlock Text="{Binding Value}"
                                               ToolTip="{Binding ValueToolTip}"
                                               Style="{DynamicResource TraceworkIdentityValueStyle}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:TraceworkPanel>

            <controls:TraceworkPanel Code="GPU.30"
                                     Title="SENSOR MATRIX"
                                     Subtitle="传感器名称、技术通道、读数与可用状态"
                                     HeaderNote="CURRENT ADAPTER"
                                     Visibility="{Binding HasGpuSensors, Converter={StaticResource BoolToVisibilityConverter}}"
                                     controls:TraceworkResponsiveGrid.WideColumnSpan="12"
                                     controls:TraceworkResponsiveGrid.WideRow="3"
                                     controls:TraceworkResponsiveGrid.StandardColumnSpan="8"
                                     controls:TraceworkResponsiveGrid.StandardRow="3"
                                     controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                     controls:TraceworkResponsiveGrid.CompactRow="5"
                                     controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                     controls:TraceworkResponsiveGrid.NarrowRow="5"
                                     Style="{DynamicResource TraceworkDataTablePanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Text="SENSOR CHANNELS"
                                   Style="{DynamicResource TraceworkChartHeaderTextStyle}" />
                        <Border Grid.Column="1" Style="{DynamicResource TraceworkRowsBadgeStyle}">
                            <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                       Style="{DynamicResource TraceworkRowsBadgeTextStyle}" />
                        </Border>
                    </Grid>

                    <DataGrid x:Name="GpuSensorDataGrid"
                              Grid.Row="2"
                              MaxHeight="320"
                              ItemsSource="{Binding SensorRows}"
                              Style="{DynamicResource TraceworkDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="名称"
                                                    Width="1.7*"
                                                    MinWidth="190"
                                                    HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   ToolTip="{Binding NameToolTip}"
                                                   Style="{DynamicResource TraceworkSensorNameTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="技术名"
                                                    Width="3*"
                                                    MinWidth="320"
                                                    HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayType}"
                                                   ToolTip="{Binding FullToolTip}"
                                                   ToolTipService.InitialShowDelay="0"
                                                   ToolTipService.ShowDuration="30000"
                                                   Style="{DynamicResource TraceworkSensorTypeTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="读数"
                                                    Width="1*"
                                                    MinWidth="130"
                                                    HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Readout}"
                                                   ToolTip="{Binding ReadoutToolTip}"
                                                   Style="{DynamicResource TraceworkSensorValueTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="状态"
                                                    Width="0.8*"
                                                    MinWidth="130"
                                                    HeaderStyle="{DynamicResource TraceworkDataGridHeaderStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Availability}"
                                                   Style="{DynamicResource TraceworkSensorStatusTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </controls:TraceworkPanel>
        </controls:TraceworkResponsiveGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
