<UserControl x:Class="HardwareVision.Views.Gpu.ClassicGpuLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{DynamicResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:GpuViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{DynamicResource RetroPageStackStyle}">
            <Border Style="{DynamicResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="GPU" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding GpuName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding GpuNameToolTip}"
                                   Style="{DynamicResource SectionTitleText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                MinWidth="260"
                                HorizontalAlignment="Right">
                        <TextBlock Text="当前 GPU" Style="{DynamicResource MetricLabelText}" />
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding GpuDevices}"
                                  SelectedItem="{Binding SelectedGpu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource FutureComboBox}"
                                  TextSearch.TextPath="Name">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GpuDevice}">
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuMetrics, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="GPU 总览" Style="{DynamicResource SectionTitleText}" />

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,8,8"
                                        Style="{DynamicResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding LabelToolTip}"
                                                   Style="{DynamicResource MetricLabelText}" />
                                        <TextBlock Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ValueToolTip}"
                                                   Style="{DynamicResource MetricValueText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="详细信息" Style="{DynamicResource SectionTitleText}" />

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding InfoItems}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,8,8"
                                        Style="{DynamicResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding LabelToolTip}"
                                                   Style="{DynamicResource MetricLabelText}" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   ToolTip="{Binding ValueToolTip}"
                                                   Style="{DynamicResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Style="{DynamicResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="实时曲线" Style="{DynamicResource SectionTitleText}" />
                        <ComboBox Grid.Column="1"
                                  Width="104"
                                  ItemsSource="{Binding ChartWindowOptions}"
                                  SelectedItem="{Binding SelectedChartWindowSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource DashboardHardwareComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0}s}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Charts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:RealtimeMetricChartViewModel}">
                                <Border Margin="0,0,8,8" Style="{DynamicResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="86" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" Style="{DynamicResource MetricLabelText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CurrentText}"
                                                       Style="{DynamicResource BodyText}" />
                                        </Grid>
                                        <controls:RealtimeLineChart Grid.Row="1"
                                                                    Margin="0,5,0,4"
                                                                    Values="{Binding Values}"
                                                                    HasData="{Binding HasData}"
                                                                    MinimumValue="{Binding MinimumValue}"
                                                                    MaximumValue="{Binding MaximumValue}"
                                                                    LineBrush="{DynamicResource AccentBrush}"
                                                                    GridLineBrush="{DynamicResource DividerBrush}"
                                                                    TextBrush="{DynamicResource TextMutedBrush}"
                                                                    EmptyText="--" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding AverageText, StringFormat={}AVG {0}}" Style="{DynamicResource CaptionText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding MinimumText, StringFormat={}MIN {0}}"
                                                       HorizontalAlignment="Center"
                                                       Style="{DynamicResource CaptionText}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding MaximumText, StringFormat={}MAX {0}}"
                                                       HorizontalAlignment="Right"
                                                       Style="{DynamicResource CaptionText}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding HasGpuSensors, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{DynamicResource RetroDataTableCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Style="{DynamicResource RetroTableHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Text="传感器"
                                   Style="{DynamicResource SectionTitleText}" />
                        <Border Grid.Column="1"
                                Style="{DynamicResource RetroRowsBadgeStyle}">
                            <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                       Style="{DynamicResource RetroRowsBadgeTextStyle}" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              MaxHeight="320"
                              ItemsSource="{Binding SensorRows}"
                              Style="{DynamicResource RetroSensorDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="名称"
                                                    Width="1.7*"
                                                    MinWidth="190"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource SensorTableNameTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="技术名"
                                                    Width="3*"
                                                    MinWidth="320"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource RetroSensorDataGridCellStyle}">
                                        <Setter Property="ToolTip" Value="{Binding FullToolTip}" />
                                        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
                                        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent"
                                                VerticalAlignment="Stretch"
                                                HorizontalAlignment="Stretch"
                                                ToolTip="{Binding FullToolTip}"
                                                ToolTipService.InitialShowDelay="0"
                                                ToolTipService.ShowDuration="30000">
                                            <TextBlock Text="{Binding DisplayType}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding FullToolTip}"
                                                       ToolTipService.InitialShowDelay="0"
                                                       ToolTipService.ShowDuration="30000"
                                                       Style="{DynamicResource SensorTableTypeTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="读数"
                                                    Width="1*"
                                                    MinWidth="130"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Readout}" Style="{DynamicResource SensorTableReadoutTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="状态"
                                                    Width="0.8*"
                                                    MinWidth="130"
                                                    HeaderStyle="{DynamicResource SensorTableHeaderCenterStyle}"
                                                    HeaderTemplate="{DynamicResource SensorTableCenterHeaderTemplate}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Availability}" Style="{DynamicResource SensorTableStatusTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
