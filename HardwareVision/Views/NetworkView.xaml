<UserControl x:Class="HardwareVision.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:NetworkViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="网络" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding SelectedAdapterName}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding SelectedAdapterSubtitle}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SectionSubtitleText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding AdapterSelectionHint}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                MinWidth="340"
                                Margin="24,0,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock Text="当前展示网卡" Style="{StaticResource MetricLabelText}" />
                        <ComboBox Margin="0,6,0,0"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{Binding NetworkAdapters}"
                                  SelectedItem="{Binding SelectedAdapter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource FutureComboBox}" />
                        <CheckBox Content="显示虚拟网卡"
                                  IsChecked="{Binding ShowVirtualAdapters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ToggleSwitch}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="当前网络总览" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="实时速率短周期刷新，IPv4、DNS、网关等静态信息低频刷新。"
                                       Style="{StaticResource SectionSubtitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StatusBadge}">
                            <TextBlock Text="{Binding VisibleAdapterSummary}"
                                       Style="{StaticResource BadgeText}" />
                        </Border>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding OverviewMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource MetricValueText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="网卡列表" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="默认隐藏虚拟、VPN、蓝牙、回环和 WAN Miniport 等适配器。"
                                       Style="{StaticResource SectionSubtitleText}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StatusBadge}">
                            <TextBlock Text="{Binding NetworkAdapters.Count, StringFormat={}{0} ADAPTERS}"
                                       Style="{StaticResource BadgeText}" />
                        </Border>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding NetworkAdapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:NetworkAdapterItemViewModel}">
                                <Border Margin="0,0,0,14"
                                        Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding Subtitle}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource CaptionText}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="16,0,0,0"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Border Style="{StaticResource StatusBadge}">
                                                    <TextBlock Text="{Binding DisplayType}"
                                                               Style="{StaticResource BadgeText}" />
                                                </Border>
                                                <Border Margin="8,0,0,0"
                                                        Style="{StaticResource StatusBadge}">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource BadgeText}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Visibility"
                                                            Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                                    <Border Margin="0,0,12,12"
                                                            ToolTip="{Binding ToolTip}"
                                                            Style="{StaticResource SensorRow}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Text="{Binding Value}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource BodyText}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Text="{Binding Source}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource CaptionText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="专业信息" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="显示当前选中网卡的 DNS、DHCP、IPv6、接口描述、累计流量和利用率。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ProfessionalMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
