<UserControl x:Class="HardwareVision.Views.AdvancedSensorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AdvancedSensorsViewModel, IsDesignTimeCreatable=True}">
    <Grid Style="{StaticResource RetroPageGridStyle}">
        <Border Style="{StaticResource RetroDataTableCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Style="{StaticResource RetroTableHeaderGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="传感器列表"
                               Style="{StaticResource SectionTitleText}" />
                    <Border Grid.Column="1"
                            Style="{StaticResource RetroRowsBadgeStyle}">
                        <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                   Style="{StaticResource RetroRowsBadgeTextStyle}" />
                    </Border>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding SensorRows}"
                          Style="{StaticResource RetroSensorDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="名称"
                                                Width="1.5*"
                                                MinWidth="150"
                                                HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                                HeaderTemplate="{StaticResource SensorTableCenterHeaderTemplate}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SensorTableNameTextStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="技术名"
                                                Width="2.5*"
                                                MinWidth="220"
                                                HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                                HeaderTemplate="{StaticResource SensorTableCenterHeaderTemplate}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayType}" Style="{StaticResource SensorTableTypeTextStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="读数"
                                                Width="1*"
                                                MinWidth="110"
                                                HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                                HeaderTemplate="{StaticResource SensorTableCenterHeaderTemplate}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Readout}" Style="{StaticResource SensorTableReadoutTextStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="状态"
                                                Width="1*"
                                                MinWidth="120"
                                                HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                                HeaderTemplate="{StaticResource SensorTableCenterHeaderTemplate}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Availability}" Style="{StaticResource SensorTableStatusTextStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
