<UserControl x:Class="HardwareVision.Views.AdvancedSensorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AdvancedSensorsViewModel, IsDesignTimeCreatable=True}">
    <Grid Style="{StaticResource RetroPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SensorRow}">
            <Grid Style="{StaticResource RetroSectionHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock VerticalAlignment="Center"
                               Text="传感器列表"
                               Style="{StaticResource SectionTitleText}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource StatusBadge}">
                    <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                               Style="{StaticResource BadgeText}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource MetricCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SensorRows}"
                          Style="{StaticResource RetroSensorDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="名称" Width="1.35*" MinWidth="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               ToolTip="{Binding NameToolTip}"
                                               Style="{StaticResource SensorTableText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="技术名" Width="1.65*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayType}"
                                               ToolTip="{Binding TypeToolTip}"
                                               Style="{StaticResource SensorTableText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="数值" Width="0.75*" MinWidth="86">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Value}"
                                               ToolTip="{Binding ValueToolTip}"
                                               Style="{StaticResource SensorTableValueText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="单位" Width="0.35*" MinWidth="46">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Unit}" Style="{StaticResource SensorTableUnitText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="可用性" Width="0.65*" MinWidth="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Availability}" Style="{StaticResource SensorTableText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
