<UserControl x:Class="HardwareVision.Views.AdvancedSensorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layouts="clr-namespace:HardwareVision.Views.AdvancedSensors"
             xmlns:models="clr-namespace:HardwareVision.Models"
             xmlns:themes="clr-namespace:HardwareVision.Themes"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <DataTemplate x:Key="ClassicAdvancedSensorsTemplate">
            <layouts:ClassicAdvancedSensorsLayout />
        </DataTemplate>
        <DataTemplate x:Key="TraceworkAdvancedSensorsTemplate">
            <layouts:TraceworkAdvancedSensorsLayout />
        </DataTemplate>
    </UserControl.Resources>

    <ContentControl x:Name="AdvancedSensorsLayoutHost"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Content="{Binding}">
        <ContentControl.Style>
            <Style TargetType="ContentControl">
                <Setter Property="ContentTemplate" Value="{StaticResource ClassicAdvancedSensorsTemplate}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=(themes:ThemeContext.CurrentTheme), RelativeSource={RelativeSource Self}}"
                                 Value="{x:Static models:AppTheme.Tracework}">
                        <Setter Property="ContentTemplate" Value="{StaticResource TraceworkAdvancedSensorsTemplate}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ContentControl.Style>
    </ContentControl>
</UserControl>
