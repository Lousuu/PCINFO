<UserControl x:Class="HardwareVision.Views.AdvancedSensorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AdvancedSensorsViewModel, IsDesignTimeCreatable=True}">
    <Grid Style="{StaticResource RetroPageGridStyle}">
        <Border Style="{StaticResource RetroDataTableCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Style="{StaticResource RetroTableHeaderGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="传感器列表"
                               Style="{StaticResource SectionTitleText}" />
                    <Border Grid.Column="1"
                            Style="{StaticResource RetroRowsBadgeStyle}">
                        <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                                   Style="{StaticResource RetroRowsBadgeTextStyle}" />
                    </Border>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding SensorRows}"
                          Style="{StaticResource RetroSensorDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称"
                                            Binding="{Binding DisplayName}"
                                            Width="1.6*"
                                            MinWidth="160"
                                            HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                            ElementStyle="{StaticResource SensorTableNameTextStyle}" />
                        <DataGridTextColumn Header="技术名"
                                            Binding="{Binding DisplayType}"
                                            Width="2.6*"
                                            MinWidth="220"
                                            HeaderStyle="{StaticResource SensorTableHeaderLeftStyle}"
                                            ElementStyle="{StaticResource SensorTableTypeTextStyle}" />
                        <DataGridTextColumn Header="读数"
                                            Binding="{Binding Readout}"
                                            Width="1*"
                                            MinWidth="120"
                                            HeaderStyle="{StaticResource SensorTableHeaderRightStyle}"
                                            ElementStyle="{StaticResource SensorTableReadoutTextStyle}" />
                        <DataGridTextColumn Header="状态"
                                            Binding="{Binding Availability}"
                                            Width="0.9*"
                                            MinWidth="95"
                                            HeaderStyle="{StaticResource SensorTableHeaderCenterStyle}"
                                            ElementStyle="{StaticResource SensorTableStatusTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
