<UserControl x:Class="HardwareVision.Views.AdvancedSensorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AdvancedSensorsViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SensorRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="完整传感器列表" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SectionSubtitleText}" />
                </StackPanel>
                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        Style="{StaticResource StatusBadge}">
                    <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} ROWS}"
                               Style="{StaticResource BadgeText}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource MetricCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="名称" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Grid.Column="1" Text="技术名" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Grid.Column="2" Text="数值" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Grid.Column="3" Text="单位" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Grid.Column="4" Text="来源" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Grid.Column="5" Text="可用性" Style="{StaticResource MetricLabelText}" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                    <ItemsControl ItemsSource="{Binding SensorRows}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailSensorRowViewModel}">
                                <Border Margin="0,0,0,8"
                                        ToolTip="{Binding ToolTip}"
                                        Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Value}" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Unit}" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Source}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Availability}" Style="{StaticResource BodyText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
