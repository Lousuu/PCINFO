<UserControl x:Class="HardwareVision.Views.MotherboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:MotherboardViewModel, IsDesignTimeCreatable=True}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SensorRow}">
                <StackPanel>
                    <TextBlock Text="主板 / 固件" Style="{StaticResource MetricLabelText}" />
                    <TextBlock Text="{Binding MotherboardName}"
                               TextWrapping="Wrap"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding DeviceSummary}"
                               TextWrapping="Wrap"
                               Style="{StaticResource SectionSubtitleText}" />
                </StackPanel>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="主板" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="来自 WMI Win32_BaseBoard 与整机 SMBIOS 信息。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding BoardMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14" ToolTip="{Binding ToolTip}" Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="BIOS/UEFI" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="BIOS 信息来自 Win32_BIOS；固件模式和 Secure Boot 可用时由 Windows 报告。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding BiosMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14" ToolTip="{Binding ToolTip}" Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="设备" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="来自 Win32_ComputerSystem、ComputerSystemProduct 和 SystemEnclosure。"
                                   Style="{StaticResource SectionSubtitleText}" />
                    </StackPanel>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding DeviceMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14" ToolTip="{Binding ToolTip}" Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Margin="0,20,0,0" Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="传感器" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="LibreHardwareMonitor Motherboard / Controller / SuperIO / EC 传感器。"
                                       Style="{StaticResource SectionSubtitleText}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StatusBadge}">
                            <TextBlock Text="{Binding SensorRows.Count, StringFormat={}{0} READINGS}"
                                       Style="{StaticResource BadgeText}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Visibility="{Binding NoSensorData, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SensorRow}">
                        <TextBlock Text="{Binding SensorStatusMessage}" Style="{StaticResource BodyText}" />
                    </Border>

                    <ItemsControl Grid.Row="4" ItemsSource="{Binding SensorMetrics}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                <Border Margin="0,0,14,14" ToolTip="{Binding ToolTip}" Style="{StaticResource SensorRow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabelText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Source}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource CaptionText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="5" ItemsSource="{Binding SensorRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DetailSensorRowViewModel}">
                                <Border Margin="0,0,0,8" ToolTip="{Binding ToolTip}" Style="{StaticResource SensorRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Value}" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Unit}" Style="{StaticResource BodyText}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Source}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
