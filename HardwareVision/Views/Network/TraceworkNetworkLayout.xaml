<UserControl x:Class="HardwareVision.Views.Network.TraceworkNetworkLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Style="{DynamicResource TraceworkPageRootStyle}"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <DataTemplate x:Key="NetworkMetricCellTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <Border ToolTip="{Binding ToolTip}"
                    Style="{DynamicResource TraceworkIdentityCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" ToolTip="{Binding LabelToolTip}" Style="{DynamicResource TraceworkIdentityLabelStyle}" />
                    <TextBlock Text="{Binding Value, TargetNullValue=--, FallbackValue=--}" ToolTip="{Binding ValueToolTip}" Style="{DynamicResource TraceworkAddressTextStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NetworkMetricRowTemplate" DataType="{x:Type viewModels:DetailMetricViewModel}">
            <Grid Margin="0,0,12,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Label}" ToolTip="{Binding LabelToolTip}" Style="{DynamicResource TraceworkMetricRowLabelStyle}" />
                <TextBlock Grid.Column="1" MaxWidth="220" Margin="8,0,0,0" Text="{Binding Value, TargetNullValue=--, FallbackValue=--}" ToolTip="{Binding ValueToolTip}" Style="{DynamicResource TraceworkMetricRowValueStyle}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="TraceworkNetworkScrollViewer"
                  Style="{DynamicResource TraceworkPageScrollViewerStyle}">
        <StackPanel Style="{DynamicResource TraceworkPageContentStackStyle}">
            <Border Style="{DynamicResource TraceworkPageHeaderStyle}">
                <StackPanel>
                    <TextBlock Text="NET.01 / LINK ROUTING" Style="{DynamicResource TraceworkPageCodeTextStyle}" />
                    <TextBlock Margin="0,4,0,0" Text="LINK TELEMETRY" Style="{DynamicResource TraceworkPageTitleTextStyle}" />
                    <TextBlock Margin="0,3,0,0" Text="网络适配器、地址与实时吞吐" Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                </StackPanel>
            </Border>

            <Border x:Name="NetworkAdapterIdentityPlate"
                    Style="{DynamicResource TraceworkIdentityPlateStyle}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ADAPTER SELECT" Style="{DynamicResource TraceworkDataStripLabelStyle}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding SelectedAdapterName}" ToolTip="{Binding SelectedAdapterName}" Style="{DynamicResource TraceworkPanelTitleTextStyle}" />
                            <TextBlock Text="{Binding SelectedAdapterSubtitle}" ToolTip="{Binding SelectedAdapterSubtitle}" Style="{DynamicResource TraceworkPanelSubtitleTextStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Top" Text="{Binding VisibleAdapterSummary}" Style="{DynamicResource TraceworkPortLabelStyle}" />
                    </Grid>
                    <ComboBox x:Name="NetworkAdapterSelector"
                              Grid.Row="1"
                              Margin="0,8,0,0"
                              ItemsSource="{Binding NetworkAdapters}"
                              SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              ToolTip="{Binding SelectedAdapterName}"
                              Style="{DynamicResource TraceworkDeviceSelectorStyle}" />
                    <StackPanel Grid.Row="2">
                        <CheckBox x:Name="NetworkVirtualAdapterToggle"
                                  Content="显示虚拟网卡"
                                  IsChecked="{Binding ShowVirtualAdapters, Mode=TwoWay}"
                                  Style="{DynamicResource TraceworkToggleStyle}" />
                        <TextBlock Margin="0,5,0,0" Text="{Binding AdapterSelectionHint}" TextWrapping="Wrap" Style="{DynamicResource TraceworkPanelSourceTextStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <controls:TraceworkResponsiveGrid x:Name="NetworkLinkTelemetryGrid"
                                              ColumnGap="18"
                                              RowGap="24">
                <controls:TraceworkPanel Code="NET.10"
                                         Title="THROUGHPUT FIELD"
                                         controls:NavigationMotion.Role="Primary"
                                         Subtitle="当前适配器实时状态"
                                         HeaderNote="LIVE VALUES"
                                         BadgeText="{Binding OverviewProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         controls:TraceworkResponsiveGrid.WideColumnSpan="8"
                                         controls:TraceworkResponsiveGrid.StandardColumnSpan="5"
                                         controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                         controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                         Style="{DynamicResource TraceworkHeroPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding OverviewProjection.PrimaryMetric.Label, TargetNullValue=--, FallbackValue=--}" Style="{DynamicResource TraceworkHeroMetricLabelStyle}" />
                            <TextBlock Text="{Binding OverviewProjection.PrimaryMetric.Value, TargetNullValue=--, FallbackValue=--}" ToolTip="{Binding OverviewProjection.PrimaryMetric.ValueToolTip}" Style="{DynamicResource TraceworkHeroMetricValueStyle}" />
                        </StackPanel>
                        <Border Grid.Row="1" Style="{DynamicResource TraceworkDividerStyle}" />
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding OverviewProjection.SecondaryMetrics}" ItemTemplate="{StaticResource NetworkMetricRowTemplate}" />
                    </Grid>
                </controls:TraceworkPanel>

                <controls:TraceworkPanel Code="NET.15"
                                         Title="ADAPTER IDENTITY"
                                         controls:NavigationMotion.Role="Secondary"
                                         Subtitle="地址、协议与累计流量"
                                         HeaderNote="USER VISIBLE"
                                         BadgeText="{Binding ProfessionalProjection.VisibleMetricCount, StringFormat={}{0} ACTIVE}"
                                         controls:TraceworkResponsiveGrid.WideColumn="8"
                                         controls:TraceworkResponsiveGrid.WideColumnSpan="4"
                                         controls:TraceworkResponsiveGrid.StandardColumn="5"
                                         controls:TraceworkResponsiveGrid.StandardColumnSpan="3"
                                         controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                                         controls:TraceworkResponsiveGrid.CompactRow="1"
                                         controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                                         controls:TraceworkResponsiveGrid.NarrowRow="1"
                                         Style="{DynamicResource TraceworkSecondaryPanelStyle}">
                    <ItemsControl ItemsSource="{Binding ProfessionalProjection.VisibleMetrics}"
                                  ItemTemplate="{StaticResource NetworkMetricCellTemplate}"
                                  Style="{DynamicResource TraceworkDenseMetricGridStyle}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </controls:TraceworkPanel>
            </controls:TraceworkResponsiveGrid>

            <controls:TraceworkPanel Code="NET.20"
                                     Title="LINK / ADDRESS MATRIX"
                                     Subtitle="可见网络适配器与原始状态"
                                     HeaderNote="NO DUPLICATE OBJECTS"
                                     BadgeText="{Binding VisibleAdapterSummary}"
                                     Style="{DynamicResource TraceworkPanelStyle}">
                <Grid>
                    <ItemsControl x:Name="NetworkAdapterNodes"
                                  ItemsSource="{Binding NetworkAdapters}"
                                  Style="{DynamicResource TraceworkTopologyMatrixStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:NetworkAdapterItemViewModel}">
                                <Border Style="{DynamicResource TraceworkTopologyNodeStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" Style="{DynamicResource TraceworkPanelTitleTextStyle}" />
                                                <TextBlock Text="{Binding Subtitle}" ToolTip="{Binding Subtitle}" Style="{DynamicResource TraceworkPanelSubtitleTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Border Style="{DynamicResource TraceworkNetworkBadgeStyle}"><TextBlock Text="{Binding DisplayType}" Style="{DynamicResource TraceworkNetworkBadgeTextStyle}" /></Border>
                                                <Border Style="{DynamicResource TraceworkNetworkStatusBadgeStyle}"><TextBlock Text="{Binding StatusText}" Style="{DynamicResource TraceworkNetworkBadgeTextStyle}" /></Border>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}" ItemTemplate="{StaticResource NetworkMetricCellTemplate}">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource TraceworkEmptyStateStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers><DataTrigger Binding="{Binding NetworkAdapters.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="未检测到可显示的网络适配器信息" Style="{DynamicResource TraceworkEmptyStateTextStyle}" />
                    </Border>
                </Grid>
            </controls:TraceworkPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
