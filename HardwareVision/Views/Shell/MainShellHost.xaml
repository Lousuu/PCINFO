<UserControl x:Class="HardwareVision.Views.Shell.MainShellHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:shell="clr-namespace:HardwareVision.Views.Shell"
             xmlns:motion="clr-namespace:HardwareVision.Themes"
             xmlns:themes="clr-namespace:HardwareVision.Themes"
             themes:ThemeContext.CurrentTheme="{Binding CurrentTheme}"
             motion:MotionContext.RequestedLevel="{Binding RequestedMotionLevel}"
             motion:MotionContext.EffectiveLevel="{Binding EffectiveMotionLevel}"
             motion:MotionContext.CurrentProfile="{Binding CurrentMotionProfile}"
             motion:MotionContext.IsAnimationEnabled="{Binding IsMotionEnabled}"
             motion:MotionContext.AllowsSpatialMotion="{Binding AllowsSpatialMotion}"
             Background="{DynamicResource AppShellBrush}">
    <Grid Background="{DynamicResource AppShellBrush}">
        <shell:ClassicShellChrome x:Name="ClassicChrome"
                                  Visibility="{Binding IsClassicTheme, Converter={StaticResource BoolToVisibilityConverter}}" />
        <shell:TraceworkShellChrome x:Name="TraceworkChrome"
                                    Visibility="{Binding IsTraceworkTheme, Converter={StaticResource BoolToVisibilityConverter}}" />

        <controls:MotionTransitionHost x:Name="PageHost"
                                       Panel.ZIndex="2"
                                       HorizontalContentAlignment="Stretch"
                                       VerticalContentAlignment="Stretch"
                                       Content="{Binding CurrentPage}"
                                       IsAutoTransitionEnabled="False"
                                       IsTransitionEnabled="{Binding IsTraceworkTheme}">
            <controls:MotionTransitionHost.Style>
                <Style TargetType="{x:Type controls:MotionTransitionHost}"
                       BasedOn="{StaticResource MotionTransitionHostStyle}">
                    <Setter Property="MaxWidth" Value="{StaticResource RetroContentMaxWidth}" />
                    <Setter Property="Margin" Value="18,128,18,42" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTraceworkTheme}" Value="True">
                            <Setter Property="MaxWidth" Value="10000" />
                            <Setter Property="Margin" Value="120,72,16,46" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:MotionTransitionHost.Style>
        </controls:MotionTransitionHost>

        <controls:RelayBandOverlay x:Name="RelayBandOverlay"
                                   Panel.ZIndex="40"
                                   Margin="{Binding Margin, ElementName=PageHost}"
                                   MaxWidth="{Binding MaxWidth, ElementName=PageHost}"
                                   HorizontalAlignment="{Binding HorizontalAlignment, ElementName=PageHost}"
                                   VerticalAlignment="Stretch"
                                   Snapshot="{Binding NavigationTransition}"
                                   Style="{StaticResource RelayBandOverlayStyle}" />

        <controls:SystemRewireOverlay x:Name="SystemRewireOverlay"
                                      Panel.ZIndex="100"
                                      IsSuppressed="{Binding IsStartupSequenceActive}"
                                      Snapshot="{Binding ThemeTransition}"
                                      Style="{StaticResource SystemRewireOverlayStyle}" />

        <shell:TraceworkStartupSequenceOverlay x:Name="StartupSequenceOverlay"
                                               Panel.ZIndex="120"
                                               Snapshot="{Binding StartupSequence}" />
    </Grid>
</UserControl>
