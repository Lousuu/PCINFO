<UserControl x:Class="HardwareVision.Views.Shell.TraceworkTimeRibbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource TraceworkTimeRibbonStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="LIVE" Style="{StaticResource TraceworkSectionCodeTextStyle}" />
                <Border Width="40"
                        Height="1"
                        Margin="9,0,4,0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource DividerBrush}" />
                <Border Width="3"
                        Height="3"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AccentBrush}" />
                <TextBlock Margin="7,0,0,0"
                           Text="SIGNAL ROUTING / STABLE"
                           Style="{DynamicResource CaptionText}" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Margin="16,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding FooterText}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding FooterText}"
                       Style="{DynamicResource CaptionText}" />

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Text="VISUAL PROFILE / TRACEWORK"
                       Style="{DynamicResource CaptionText}" />
        </Grid>
    </Border>
</UserControl>
