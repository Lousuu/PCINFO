<UserControl x:Class="HardwareVision.Views.Shell.StartupMilestoneRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             IsTabStop="False"
             Height="34">
    <UserControl.Resources>
        <Style x:Key="MilestoneNodeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource TraceworkDustGreyBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Pending">
                    <Setter Property="Background" Value="{DynamicResource TraceworkTelemetryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Ready">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Partial">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Failed">
                    <Setter Property="Background" Value="{DynamicResource CriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MilestoneStatusStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TraceworkDustGreyBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Pending">
                    <Setter Property="Foreground" Value="{DynamicResource TraceworkTelemetryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Ready">
                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Partial">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Failed">
                    <Setter Property="Foreground" Value="{DynamicResource CriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TerminalLockSegmentStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Partial">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Failed">
                    <Setter Property="Background" Value="{DynamicResource CriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RowRoot" Height="34">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border x:Name="UpperRouteSegment"
                    Width="1" Height="17"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{DynamicResource TraceworkTraceGreyBrush}" />
            <Border x:Name="LowerRouteSegment"
                    Width="1" Height="17"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource TraceworkTraceGreyBrush}" />
            <Border x:Name="MilestoneNode"
                    Width="4" Height="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource MilestoneNodeStyle}" />
            <Grid x:Name="TerminalLockFrame"
                  Width="12" Height="12"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Opacity="0"
                  IsHitTestVisible="False">
                <Border Width="5" Height="1" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="1" Height="5" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="5" Height="1" HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="1" Height="5" HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="5" Height="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="1" Height="5" HorizontalAlignment="Left" VerticalAlignment="Bottom" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="5" Height="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource TerminalLockSegmentStyle}" />
                <Border Width="1" Height="5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource TerminalLockSegmentStyle}" />
            </Grid>
        </Grid>

        <TextBlock x:Name="MilestoneName"
                   Grid.Column="1"
                   Text="{Binding Name}"
                   VerticalAlignment="Center"
                   Style="{DynamicResource TraceworkMetricRowLabelStyle}">
            <TextBlock.RenderTransform>
                <TranslateTransform />
            </TextBlock.RenderTransform>
        </TextBlock>
        <TextBlock x:Name="MilestoneStatus"
                   Grid.Column="2"
                   Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   Style="{StaticResource MilestoneStatusStyle}" />
        <TextBlock x:Name="MilestoneDetail"
                   Grid.Column="3"
                   Text="{Binding Detail}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Style="{DynamicResource TraceworkAnnotationTextStyle}" />
    </Grid>
</UserControl>
