<UserControl x:Class="HardwareVision.Views.Dashboard.ClassicDashboardLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Background="{DynamicResource AppBackgroundBrush}">
    <ScrollViewer x:Name="ClassicDashboardScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{DynamicResource RetroPageStackStyle}">
            <Border Style="{DynamicResource SensorRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="应用" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding ApplicationName}" Style="{DynamicResource SectionTitleText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="当前设备" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding DeviceName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DeviceNameToolTip}"
                                   Style="{DynamicResource BodyText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="系统版本" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding OperatingSystem}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding OperatingSystemToolTip}"
                                   Style="{DynamicResource BodyText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                        <TextBlock Text="最后刷新" Style="{DynamicResource MetricLabelText}" />
                        <TextBlock Text="{Binding LastRefreshTime}" Style="{DynamicResource BodyText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding OverviewCards}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility"
                                Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:HardwareOverviewCardViewModel}">
                        <Border Margin="0,0,8,8"
                                Style="{DynamicResource MetricCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding Title}" Style="{DynamicResource MetricLabelText}" />

                                <Grid Grid.Row="1" Margin="0,4,0,8" MinHeight="28">
                                    <TextBlock Text="{Binding HardwareName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding HardwareNameToolTip}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding HasHardwareSelector}" Value="True" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ComboBox Margin="0"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding HardwareOptions}"
                                              SelectedItem="{Binding SelectedHardwareOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Visibility="{Binding HasHardwareSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource DashboardHardwareComboBox}">
                                                <Setter Property="Opacity" Value="0" />
                                                <Setter Property="IsHitTestVisible" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="IsHitTestVisible" Value="True" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="IsHitTestVisible" Value="True" />
                                                    </Trigger>
                                                    <Trigger Property="IsDropDownOpen" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="IsHitTestVisible" Value="True" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:HardwareSelectionOptionViewModel}">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding ToolTip}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility"
                                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Label}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding LabelToolTip}"
                                                           Style="{DynamicResource MetricLabelText}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="10,0,0,0"
                                                           Text="{Binding Value}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding ValueToolTip}"
                                                           Style="{DynamicResource BodyText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
