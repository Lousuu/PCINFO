<UserControl x:Class="HardwareVision.Views.Dashboard.TraceworkDashboardLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             xmlns:controls="clr-namespace:HardwareVision.Controls"
             xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
             Style="{DynamicResource TraceworkPageRootStyle}"
             Background="{DynamicResource TraceworkCanvasBrush}">
    <UserControl.Resources>
        <DataTemplate x:Key="DashboardInstrumentTemplate"
                      DataType="{x:Type viewModels:HardwareOverviewCardViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ComboBox ItemsSource="{Binding HardwareOptions}"
                          SelectedItem="{Binding SelectedHardwareOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Visibility="{Binding HasHardwareSelector, Converter={StaticResource BoolToVisibilityConverter}}"
                          ToolTip="{Binding HardwareSelectorToolTip}"
                          automation:AutomationProperties.Name="{Binding HardwareSelectorAutomationName}"
                          Style="{DynamicResource TraceworkDashboardSelectorStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:HardwareSelectionOptionViewModel}">
                            <TextBlock Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ToolTip}"
                                       automation:AutomationProperties.Name="{Binding DisplayName}"
                                       Foreground="{DynamicResource TraceworkPaperBrush}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding PrimaryMetric.Label, TargetNullValue=--, FallbackValue=--}"
                                   ToolTip="{Binding PrimaryMetric.LabelToolTip}"
                                   Style="{DynamicResource TraceworkInstrumentLabelStyle}" />
                        <TextBlock Text="{Binding PrimaryMetric.Value, TargetNullValue=--, FallbackValue=--}"
                                   ToolTip="{Binding PrimaryMetric.ValueToolTip}"
                                   Style="{DynamicResource TraceworkInstrumentValueStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" MaxWidth="220" VerticalAlignment="Bottom">
                        <TextBlock HorizontalAlignment="Right"
                                   Text="{Binding Title}"
                                   Style="{DynamicResource TraceworkSectionTitleTextStyle}" />
                        <TextBlock Margin="0,3,0,0"
                                   HorizontalAlignment="Right"
                                   Text="{Binding HardwareName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding HardwareNameToolTip}"
                                   automation:AutomationProperties.Name="{Binding HardwareName}"
                                   Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                        <TextBlock Margin="0,2,0,0"
                                   HorizontalAlignment="Right"
                                   Text="{Binding HeaderNote}"
                                   Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Height="1"
                        Margin="0,12,0,10"
                        Background="{DynamicResource TraceworkTelemetryBrush}"
                        IsHitTestVisible="False"
                        Focusable="False" />

                <ItemsControl Grid.Row="3" ItemsSource="{Binding SecondaryMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:AdaptiveUniformGrid MaximumColumns="2"
                                                          MinItemWidth="180"
                                                          HorizontalGap="16"
                                                          VerticalGap="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Label}"
                                           ToolTip="{Binding LabelToolTip}"
                                           Style="{DynamicResource TraceworkMetricRowLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Text="{Binding Value}"
                                           ToolTip="{Binding ValueToolTip}"
                                           Foreground="{DynamicResource TraceworkTelemetryBrush}"
                                           Style="{DynamicResource TraceworkMetricRowValueStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DashboardTelemetryModuleTemplate"
                      DataType="{x:Type viewModels:HardwareOverviewCardViewModel}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{DynamicResource TraceworkSectionTitleTextStyle}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding HardwareName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding HardwareNameToolTip}"
                                   automation:AutomationProperties.Name="{Binding HardwareName}"
                                   Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding VisibleMetricCount, StringFormat={}{0:00}}"
                               Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                </Grid>

                <ComboBox Margin="0,8,0,8"
                          ItemsSource="{Binding HardwareOptions}"
                          SelectedItem="{Binding SelectedHardwareOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Visibility="{Binding HasHardwareSelector, Converter={StaticResource BoolToVisibilityConverter}}"
                          ToolTip="{Binding HardwareSelectorToolTip}"
                          automation:AutomationProperties.Name="{Binding HardwareSelectorAutomationName}"
                          Style="{DynamicResource TraceworkDashboardSelectorStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:HardwareSelectionOptionViewModel}">
                            <TextBlock Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ToolTip}"
                                       automation:AutomationProperties.Name="{Binding DisplayName}"
                                       Foreground="{DynamicResource TraceworkPaperBrush}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Visibility"
                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:DetailMetricViewModel}">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Label}"
                                           ToolTip="{Binding LabelToolTip}"
                                           Style="{DynamicResource TraceworkMetricRowLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Text="{Binding Value, TargetNullValue=--, FallbackValue=--}"
                                           ToolTip="{Binding ValueToolTip}"
                                           Style="{DynamicResource TraceworkMetricRowValueStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="TraceworkDashboardScrollViewer"
                  Style="{DynamicResource TraceworkPageScrollViewerStyle}">
        <StackPanel Style="{DynamicResource TraceworkPageContentStackStyle}">
            <Border Style="{DynamicResource TraceworkEditorialPageHeaderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SYS.00"
                               Style="{DynamicResource TraceworkPageIndexTextStyle}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock Text="SYSTEM STATE"
                                   Style="{DynamicResource TraceworkSectionTitleTextStyle}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="当前系统核心状态"
                                   Style="{DynamicResource TraceworkPageSubtitleTextStyle}" />
                    </StackPanel>
                    <Border Grid.Column="3"
                            MaxWidth="300"
                            HorizontalAlignment="Right"
                            Style="{DynamicResource TraceworkAnnotationRailStyle}">
                        <StackPanel>
                            <TextBlock HorizontalAlignment="Right"
                                       Text="{Binding ApplicationName}"
                                       Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                            <TextBlock Margin="0,3,0,0"
                                       HorizontalAlignment="Right"
                                       Text="{Binding LastRefreshTime}"
                                       Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                            <TextBlock Margin="0,3,0,0"
                                       HorizontalAlignment="Right"
                                       Text="{Binding LoadMessage}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LoadMessage}"
                                       Style="{DynamicResource TraceworkAnnotationTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <controls:TraceworkResponsiveGrid x:Name="DashboardEditorialGrid"
                                              ColumnGap="12"
                                              RowGap="24">
                <Border x:Name="DashboardPrimaryRegion"
                        controls:NavigationMotion.Role="Primary"
                        controls:TraceworkResponsiveGrid.WideColumn="0"
                        controls:TraceworkResponsiveGrid.WideColumnSpan="7"
                        controls:TraceworkResponsiveGrid.WideRow="0"
                        controls:TraceworkResponsiveGrid.StandardColumn="0"
                        controls:TraceworkResponsiveGrid.StandardColumnSpan="5"
                        controls:TraceworkResponsiveGrid.StandardRow="0"
                        controls:TraceworkResponsiveGrid.CompactColumn="0"
                        controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                        controls:TraceworkResponsiveGrid.CompactRow="0"
                        controls:TraceworkResponsiveGrid.NarrowColumn="0"
                        controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                        controls:TraceworkResponsiveGrid.NarrowRow="0"
                        DataContext="{Binding CpuOverviewCard}"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{DynamicResource TraceworkInstrumentFieldStyle}">
                    <ContentControl x:Name="CpuPrimaryInstrument"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource DashboardInstrumentTemplate}" />
                </Border>

                <StackPanel x:Name="DashboardSecondaryRegion"
                            controls:NavigationMotion.Role="Secondary"
                            controls:TraceworkResponsiveGrid.WideColumn="7"
                            controls:TraceworkResponsiveGrid.WideColumnSpan="5"
                            controls:TraceworkResponsiveGrid.WideRow="0"
                            controls:TraceworkResponsiveGrid.StandardColumn="5"
                            controls:TraceworkResponsiveGrid.StandardColumnSpan="3"
                            controls:TraceworkResponsiveGrid.StandardRow="0"
                            controls:TraceworkResponsiveGrid.CompactColumn="0"
                            controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                            controls:TraceworkResponsiveGrid.CompactRow="1"
                            controls:TraceworkResponsiveGrid.NarrowColumn="0"
                            controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                            controls:TraceworkResponsiveGrid.NarrowRow="1">
                    <Border x:Name="GpuTelemetryField"
                            Margin="0,0,0,16"
                            Padding="16,14"
                            DataContext="{Binding GpuOverviewCard}"
                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource TraceworkTelemetrySoftBrush}"
                            BorderBrush="{DynamicResource TraceworkTelemetryBrush}"
                            BorderThickness="2,0,0,1">
                        <ContentControl Content="{Binding}"
                                        ContentTemplate="{StaticResource DashboardTelemetryModuleTemplate}" />
                    </Border>

                    <controls:AdaptiveUniformGrid Margin="0,0,0,16"
                                                  MaximumColumns="2"
                                                  MinItemWidth="220"
                                                  HorizontalGap="12"
                                                  VerticalGap="12">
                        <controls:TraceworkPanel x:Name="MemorySecondaryModule"
                                                 DataContext="{Binding MemoryOverviewCard}"
                                                 Code="MEM.03"
                                                 Title="{Binding Title}"
                                                 Subtitle="{Binding HardwareName}"
                                                 HeaderNote="{Binding HeaderNote}"
                                                 BadgeText="{Binding VisibleMetricCount, StringFormat={}{0:00}}"
                                                 Content="{Binding}"
                                                 ContentTemplate="{StaticResource DashboardTelemetryModuleTemplate}"
                                                 Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 Style="{DynamicResource TraceworkTechnicalPanelStyle}" />
                        <controls:TraceworkPanel x:Name="DiskSecondaryModule"
                                                 DataContext="{Binding DiskOverviewCard}"
                                                 Code="DSK.04"
                                                 Title="{Binding Title}"
                                                 Subtitle="{Binding HardwareName}"
                                                 HeaderNote="{Binding HeaderNote}"
                                                 BadgeText="{Binding VisibleMetricCount, StringFormat={}{0:00}}"
                                                 Content="{Binding}"
                                                 ContentTemplate="{StaticResource DashboardTelemetryModuleTemplate}"
                                                 Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 Style="{DynamicResource TraceworkTechnicalPanelStyle}" />
                    </controls:AdaptiveUniformGrid>

                    <controls:AdaptiveUniformGrid MaximumColumns="2"
                                                  MinItemWidth="220"
                                                  HorizontalGap="12"
                                                  VerticalGap="12">
                        <Border x:Name="NetworkSecondaryModule"
                                Padding="12,10"
                                DataContext="{Binding NetworkOverviewCard}"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource TraceworkDividerBrush}"
                                BorderThickness="0,1,0,0">
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource DashboardTelemetryModuleTemplate}" />
                        </Border>
                        <Border x:Name="SystemSecondaryModule"
                                Padding="12,10"
                                DataContext="{Binding SystemOverviewCard}"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource TraceworkDividerBrush}"
                                BorderThickness="0,1,0,0">
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource DashboardTelemetryModuleTemplate}" />
                        </Border>
                    </controls:AdaptiveUniformGrid>
                </StackPanel>

                <Border x:Name="DashboardDataRail"
                        controls:TraceworkResponsiveGrid.WideColumn="0"
                        controls:TraceworkResponsiveGrid.WideColumnSpan="12"
                        controls:TraceworkResponsiveGrid.WideRow="1"
                        controls:TraceworkResponsiveGrid.StandardColumn="0"
                        controls:TraceworkResponsiveGrid.StandardColumnSpan="8"
                        controls:TraceworkResponsiveGrid.StandardRow="1"
                        controls:TraceworkResponsiveGrid.CompactColumn="0"
                        controls:TraceworkResponsiveGrid.CompactColumnSpan="4"
                        controls:TraceworkResponsiveGrid.CompactRow="2"
                        controls:TraceworkResponsiveGrid.NarrowColumn="0"
                        controls:TraceworkResponsiveGrid.NarrowColumnSpan="1"
                        controls:TraceworkResponsiveGrid.NarrowRow="2"
                        Style="{DynamicResource TraceworkDataRailStyle}">
                    <WrapPanel HorizontalAlignment="Stretch">
                        <Border Style="{DynamicResource TraceworkDataRailItemStyle}">
                            <StackPanel>
                                <TextBlock Text="NODE" Style="{DynamicResource TraceworkDataRailLabelStyle}" />
                                <TextBlock Text="{Binding DeviceName}"
                                           ToolTip="{Binding DeviceNameToolTip}"
                                           automation:AutomationProperties.Name="{Binding DeviceName}"
                                           Style="{DynamicResource TraceworkDataRailValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource TraceworkDataRailItemStyle}">
                            <StackPanel>
                                <TextBlock Text="PLATFORM" Style="{DynamicResource TraceworkDataRailLabelStyle}" />
                                <TextBlock Text="{Binding OperatingSystem}"
                                           ToolTip="{Binding OperatingSystemToolTip}"
                                           automation:AutomationProperties.Name="{Binding OperatingSystem}"
                                           Style="{DynamicResource TraceworkDataRailValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource TraceworkDataRailItemStyle}">
                            <StackPanel>
                                <TextBlock Text="UPDATED" Style="{DynamicResource TraceworkDataRailLabelStyle}" />
                                <TextBlock Text="{Binding LastRefreshTime}"
                                           Style="{DynamicResource TraceworkDataRailValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource TraceworkDataRailItemStyle}">
                            <StackPanel>
                                <TextBlock Text="STATE" Style="{DynamicResource TraceworkDataRailLabelStyle}" />
                                <TextBlock Text="{Binding LoadMessage}"
                                           ToolTip="{Binding LoadMessage}"
                                           Style="{DynamicResource TraceworkDataRailValueStyle}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Border>
            </controls:TraceworkResponsiveGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
