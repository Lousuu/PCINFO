<Window x:Class="HardwareVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
        xmlns:views="clr-namespace:HardwareVision.Views"
        Title="{Binding ApplicationName}"
        Width="1120"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppShellBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{DynamicResource AppFontFamily}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel, IsDesignTimeCreatable=True}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:AdvancedSensorsViewModel}">
            <views:AdvancedSensorsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:CpuViewModel}">
            <views:CpuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:GpuViewModel}">
            <views:GpuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MemoryViewModel}">
            <views:MemoryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:DiskViewModel}">
            <views:DiskView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MotherboardViewModel}">
            <views:MotherboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:NetworkViewModel}">
            <views:NetworkView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:GamePerformanceViewModel}">
            <views:GamePerformanceView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MetricVisibilityViewModel}">
            <views:MetricVisibilityView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="112" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource SidebarPanel}">
            <Grid x:Name="ShellContentFrame"
                  MaxWidth="{StaticResource RetroContentMaxWidth}"
                  Margin="18,12"
                  HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ApplicationName}" Style="{DynamicResource ShellTitleText}" />
                        <Border Margin="12,0,0,0" Style="{DynamicResource StatusBadge}">
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding CurrentPageTitle}"
                                       Style="{DynamicResource BadgeText}" />
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{Binding StatusText}"
                               Foreground="{DynamicResource CardBackgroundBrush}"
                               TextTrimming="CharacterEllipsis"
                               Style="{DynamicResource CaptionText}" />
                </Grid>

                <ItemsControl Grid.Row="2"
                              HorizontalAlignment="Center"
                              ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:NavigationItemViewModel}">
                            <Button Content="{Binding Title}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding IsEnabled}"
                                    Style="{DynamicResource RetroNavButtonStyle}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        MaxWidth="{StaticResource RetroContentMaxWidth}"
                        Width="{Binding ActualWidth, ElementName=ShellContentFrame}"
                        Margin="0,16,0,14"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Content="{Binding CurrentPage}" />

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundAltBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock MaxWidth="{StaticResource RetroContentMaxWidth}"
                       Margin="18,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding FooterText}"
                       Style="{DynamicResource CaptionText}" />
        </Border>
    </Grid>
</Window>
