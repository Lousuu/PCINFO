<Window x:Class="HardwareVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:HardwareVision.Views.Shell"
        xmlns:viewModels="clr-namespace:HardwareVision.ViewModels"
        xmlns:views="clr-namespace:HardwareVision.Views"
        Title="{Binding ApplicationName}"
        Width="1120"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppShellBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{DynamicResource AppFontFamily}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel, IsDesignTimeCreatable=True}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:AdvancedSensorsViewModel}">
            <views:AdvancedSensorsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:CpuViewModel}">
            <views:CpuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:GpuViewModel}">
            <views:GpuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MemoryViewModel}">
            <views:MemoryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:DiskViewModel}">
            <views:DiskView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MotherboardViewModel}">
            <views:MotherboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:NetworkViewModel}">
            <views:NetworkView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:GamePerformanceViewModel}">
            <views:GamePerformanceView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MetricVisibilityViewModel}">
            <views:MetricVisibilityView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <shell:MainShellHost />
</Window>
